<UserControl x:Class="ARK.UI.Views.BlueprintEditorControl"
             Loaded="OnControlLoaded"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ARK.UI.Core.Models"
             xmlns:nodes="clr-namespace:ARK.UI.Core.Nodes"
             xmlns:obsNodes="clr-namespace:ARK.UI.Core.Nodes.OBS"
             xmlns:converters="clr-namespace:ARK.UI.Converters"
             xmlns:res="clr-namespace:ARK.UI.Resources">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Inputs.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертеры -->
            <converters:HotKeyTextConverter x:Key="HotKeyTextConverter"/>
            <converters:EnumToLocalizedDescriptionConverter x:Key="EnumToLocalizedDescriptionConverter"/>

            <!-- ══ Стиль тултипа ObsidianToolTipStyle ════════════════════════ -->
            <Style x:Key="ObsidianToolTipStyle" TargetType="ToolTip">
                <Setter Property="Background"        Value="Transparent"/>
                <Setter Property="BorderThickness"   Value="0"/>
                <Setter Property="Padding"           Value="0"/>
                <Setter Property="HasDropShadow"     Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="#F2121212"
                                    BorderBrush="#FFD4AF37" BorderThickness="1"
                                    CornerRadius="6" Padding="12,9">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Стиль кнопки-справки [?] ObsidianHelpButtonStyle ══════════ -->
            <Style x:Key="ObsidianHelpButtonStyle" TargetType="Button">
                <Setter Property="Width"        Value="16"/>
                <Setter Property="Height"       Value="16"/>
                <Setter Property="Cursor"       Value="Help"/>
                <Setter Property="Focusable"    Value="False"/>
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Width="16" Height="16" CornerRadius="8"
                                    Background="Transparent"
                                    BorderBrush="#FFD4AF37" BorderThickness="1">
                                <TextBlock Text="?"
                                           Foreground="#FFD4AF37"
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,-1,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Effect"
                                            Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Стиль маркера-памятки [!] ObsidianWarnButtonStyle ══════════ -->
            <Style x:Key="ObsidianWarnButtonStyle" TargetType="Button">
                <Setter Property="Width"        Value="16"/>
                <Setter Property="Height"       Value="16"/>
                <Setter Property="Cursor"       Value="Help"/>
                <Setter Property="Focusable"    Value="False"/>
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Width="16" Height="16" CornerRadius="8"
                                    Background="Transparent"
                                    BorderBrush="#FFD4AF37" BorderThickness="1">
                                <TextBlock Text="!"
                                           Foreground="#FFF5D77F"
                                           FontFamily="Segoe UI" FontWeight="Bold" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,-1,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Effect"
                                            Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Шаблоны свойств нод ══════════════════════════════════════ -->

            <DataTemplate DataType="{x:Type nodes:DelayNode}">
                <StackPanel>
                    <!-- Флаг случайной задержки -->
                    <CheckBox Content="{x:Static res:Strings.Node_DelayRandom}"
                              IsChecked="{Binding IsDelayRandom}"
                              Foreground="#FFF5D77F" Margin="0,0,0,8"/>

                    <!-- Статический режим: одно поле задержки -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDelayRandom}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Node_DelayMs}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                                <Button.ToolTip>
                                    <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="ЗАДЕРЖКА ВЫПОЛНЕНИЯ"
                                                       Foreground="#FFF5D77F" FontFamily="Consolas"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                            <TextBlock Text="Приостанавливает выполнение макроса на заданное время в миллисекундах."
                                                       Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                       TextWrapping="Wrap" Margin="0,0,0,10"/>
                                            <TextBlock Margin="0,0,0,4">
                                                <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <Run Text="Передаёт фактически выжданное время задержки (например, «1134») дальше по серебряному проводу данных."
                                                     Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <Run Text="Принимает динамическое значение задержки в виде числа (например, 1000) или строки (например, «2500») по серебряному проводу данных."
                                                     Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                        <TextBox Text="{Binding DelayMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"/>
                    </StackPanel>

                    <!-- Случайный режим: Min и Max в двух колонках -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDelayRandom}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Static res:Strings.Node_DelayMin}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MinDelayMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#FFF5D77F"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{x:Static res:Strings.Node_DelayMax}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MaxDelayMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#FFF5D77F"/>
                        </StackPanel>
                    </Grid>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:OverlayTextNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_OverlayText}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"
                             TextWrapping="Wrap" AcceptsReturn="False" MaxLines="3"
                             Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static res:Strings.Node_DurationMs}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DurationMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"/>
                </StackPanel>
            </DataTemplate>

            <!-- TriggerRootNode: панель свойств — только информационная плашка -->
            <DataTemplate DataType="{x:Type nodes:TriggerRootNode}">
                <StackPanel>
                    <TextBlock Text="ТОЧКА ВХОДА МАКРОСА"
                               Foreground="{StaticResource GoldBrush}"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                               Text="Все триггерные ноды (Хоткей, Голос) соединяются через зелёный провод Success к этой ноде. Выполнение графа начинается здесь."/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:HotkeyTriggerNode}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Blueprint_HotkeyLabel}"
                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ГЛОБАЛЬНЫЙ ТРИГГЕР КЛАВИШ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Запускает выполнение макроса при нажатии заданной комбинации клавиш в системе."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт название нажатой комбинации клавиш в виде текстовой строки (например, «Ctrl+Shift+F12») дальше по серебряному проводу данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Позволяет динамически изменить отслеживаемую комбинацию клавиш во время выполнения макроса, приняв текстовую строку (например, «Ctrl+Shift+F12») по серебряному проводу данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox IsReadOnly="True" Foreground="#FFF5D77F"
                             Cursor="IBeam" Focusable="True"
                             Margin="0,0,0,3"
                             PreviewKeyDown="OnHotKeyBoxPreviewKeyDown"
                             ToolTip="{x:Static res:Strings.Node_KeyTooltip}">
                        <TextBox.Text>
                            <MultiBinding Converter="{StaticResource HotKeyTextConverter}" Mode="OneWay">
                                <Binding Path="HotKey"/>
                                <Binding Path="HotKeyModifiers"/>
                            </MultiBinding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBlock Text="{x:Static res:Strings.Node_KeyInputHint}"
                               Foreground="#FF444444" FontSize="9" FontFamily="Segoe UI"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static res:Strings.Node_HotkeyHint}"
                               Foreground="#FF666666" FontSize="10" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:SpeechTriggerNode}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_SpeechTriggerPhrases}"
                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ГЛОБАЛЬНЫЙ ГОЛОСОВОЙ ТРИГГЕР"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Запускает выполнение макроса при распознавании одной из фраз-синонимов в микрофоне."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт точную распознанную Whisper фразу дальше по серебряному проводу данных (например, на оверлей или в ИИ-запрос)."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Позволяет программно активировать ноду, если по серебряному проводу прилетел сторонний текст (например, из Twitch-чата), совпадающий с одним из синонимов."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Text="Слова в синонимах можно менять местами: фразы «Арк, открой музыку» и «Включи музыку, Арк» сработают одинаково успешно."
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox Text="{Binding PhrasesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="120"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsTab="False"
                             Tag="{x:Static res:Strings.Node_SpeechTriggerPlaceholder}"
                             Margin="0,0,0,4"/>
                    <!-- Главное ключевое слово (корень/подстрока) -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,4" VerticalAlignment="Center">
                        <TextBlock Text="ГЛАВНОЕ КЛЮЧЕВОЕ СЛОВО"
                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ФИЛЬТР ПО КОРНЮ СЛОВА"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Укажите обязательную часть слова или корень (например: 'музык' или 'свет'). Система ищет вхождение этой части в распознанном тексте. Это позволит вам произносить слово в любых падежах и с любыми окончаниями ('музыку', 'музыка', 'музыкой') без потери распознавания."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox Text="{Binding RequiredKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Tag="укажите часть слова/корень..."
                             Foreground="#FFF5D77F"
                             Margin="0,0,0,4"/>

                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:SendInputNode}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_KeyLabel}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ЭМУЛЯЦИЯ НАЖАТИЯ КЛАВИШ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Физически симулирует нажатие заданной комбинации клавиш в активном окне Windows."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт фактически нажатую комбинацию клавиш в виде текстовой строки (например, «Ctrl+Shift+T») дальше по серебряному проводу данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Позволяет динамически изменить нажимаемую клавишу («TargetKey») или модификаторы («TargetModifiers») во время выполнения макроса, приняв текстовую строку по серебряному проводу данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox IsReadOnly="True" Foreground="#FFF5D77F"
                             Cursor="IBeam" Focusable="True"
                             Margin="0,0,0,3"
                             PreviewKeyDown="OnTargetKeyBoxPreviewKeyDown"
                             ToolTip="{x:Static res:Strings.Node_KeyTooltip}">
                        <TextBox.Text>
                            <MultiBinding Converter="{StaticResource HotKeyTextConverter}"
                                          Mode="OneWay">
                                <Binding Path="TargetKey"/>
                                <Binding Path="TargetModifiers"/>
                            </MultiBinding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBlock Text="{x:Static res:Strings.Node_KeyInputHint}"
                               Foreground="#FF444444" FontSize="9" FontFamily="Segoe UI"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static res:Strings.Node_ModifiersLabel}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox Content="Ctrl"  IsChecked="{Binding IsCtrl}"  Margin="0,0,10,0"/>
                        <CheckBox Content="Shift" IsChecked="{Binding IsShift}" Margin="0,0,10,0"/>
                        <CheckBox Content="Alt"   IsChecked="{Binding IsAlt}"   Margin="0,0,10,0"/>
                        <CheckBox Content="Win"   IsChecked="{Binding IsWin}"/>
                    </StackPanel>
                    <CheckBox Content="{x:Static res:Strings.Node_SendInput_RandomDelay}"
                              IsChecked="{Binding IsDelayRandom}" Margin="0,0,0,8"/>
                    <!-- Фиксированная задержка -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDelayRandom}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_DelayAfterMs}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DelayAfterMs, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"/>
                    </StackPanel>
                    <!-- Диапазон задержки -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDelayRandom}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Static res:Strings.Node_SendInput_MinDelay}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MinDelayAfterMs, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#FFF5D77F"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{x:Static res:Strings.Node_SendInput_MaxDelay}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MaxDelayAfterMs, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#FFF5D77F"/>
                        </StackPanel>
                    </Grid>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:MouseActionNode}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_MouseActionType}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="УПРАВЛЕНИЕ МЫШЬЮ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Симулирует клики, движение курсора или прокрутку колесика мыши в системе."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт информацию о совершённом действии и координатах (например, «LeftClick (1280, 720)») дальше по серебряному проводу данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Позволяет динамически получить координаты X и Y (например, от ноды поиска изображения на экране) по серебряному проводу данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:MouseActionNode.AllActionTypes}}"
                              SelectedItem="{Binding ActionType}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F"
                                               Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- X и Y: скрыты только при Scroll -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActionType}"
                                                 Value="{x:Static nodes:MouseActionType.Scroll}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_MouseX}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F" Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Static res:Strings.Node_MouseY}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F" Margin="0,0,0,6"/>
                        <!-- Кнопка визуального захвата координат -->
                        <Button Command="{Binding DataContext.CaptureCoordinatesCommand,
                                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                CommandParameter="{Binding}"
                                Margin="0,0,0,6"
                                Cursor="Hand"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            BorderBrush="#33F5D77F"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="6,4">
                                        <TextBlock Text="◎ ЗАХВАТИТЬ КООРДИНАТЫ"
                                                   Foreground="#FFF5D77F"
                                                   FontFamily="Consolas"
                                                   FontSize="9"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#88F5D77F"/>
                                            <Setter TargetName="Bd" Property="Background" Value="#15F5D77F"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#25F5D77F"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <!-- ScrollAmount: видимо только при Scroll -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActionType}"
                                                 Value="{x:Static nodes:MouseActionType.Scroll}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_ScrollAmount}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ScrollAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"/>
                    </StackPanel>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:RunProcessNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_ActiveProcessLabel}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.ActiveSystemProcesses,
                                                   RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding DataContext.SelectedActiveProcess,
                                                     RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0"
                                           Source="{Binding Icon}"
                                           Width="16" Height="16"
                                           Margin="0,0,8,0"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1" ClipToBounds="True" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProcessName}"
                                                   Foreground="#FFF5D77F"
                                                   Style="{StaticResource MarqueeTextBlockStyle}"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- ПУТЬ / URL + [?] -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_FilePathOrUrl}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ПУТЬ К ПРОГРАММЕ ИЛИ URL-ССЫЛКЕ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <!-- Пример 1 -->
                                        <TextBlock Text="Пример 1: Открытие локального текстового файла через Блокнот (Notepad)"
                                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,3"/>
                                        <TextBlock Margin="0,0,0,1">
                                            <Run Text="Поле ПУТЬ / URL:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="notepad.exe" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,8">
                                            <Run Text="Поле АРГУМЕНТЫ:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="C:\Folder\file.txt" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <!-- Пример 2 -->
                                        <TextBlock Text="Пример 2: Запуск установленной программы (Яндекс.Музыка) из папки пользователя"
                                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,3"/>
                                        <TextBlock Margin="0,0,0,1">
                                            <Run Text="Поле ПУТЬ / URL:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="C:\Users\Username\AppData\Local\Programs\YandexMusic\YandexMusic.exe" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,8">
                                            <Run Text="Поле АРГУМЕНТЫ:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="YandexMusic.exe" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <!-- Пример 3 -->
                                        <TextBlock Text="Пример 3: Открытие веб-сайта в приватном режиме (Инкогнито) через Google Chrome"
                                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,3"/>
                                        <TextBlock Margin="0,0,0,1">
                                            <Run Text="Поле ПУТЬ / URL:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="C:\Program Files\Google\Chrome\Application\chrome.exe" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,8">
                                            <Run Text="Поле АРГУМЕНТЫ:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="--incognito https://www.youtube.com/" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <!-- Пример 4 -->
                                        <TextBlock Text="Пример 4: Открытие обычного сайта в браузере по умолчанию (Обычный режим)"
                                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,3"/>
                                        <TextBlock Margin="0,0,0,1">
                                            <Run Text="Поле ПУТЬ / URL:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="https://www.youtube.com/" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Поле АРГУМЕНТЫ:  " Foreground="#FF666666" FontFamily="Consolas" FontSize="9"/>
                                            <Run Text="(Оставить пустым)" Foreground="#FF666666" FontFamily="Consolas" FontSize="9" FontStyle="Italic"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox Text="{Binding FilePathOrUrl, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Margin="0,0,0,10"/>
                    <!-- АРГУМЕНТЫ -->
                    <TextBlock Text="{x:Static res:Strings.Node_Arguments}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,8"/>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:Web_RequestNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_WebRequest_Method}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:Web_RequestNode.AllMethods}}"
                              SelectedItem="{Binding Method}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static res:Strings.Node_WebRequest_Url}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,10"
                             Tag="https://api.example.com/endpoint"/>
                    <TextBlock Text="{x:Static res:Strings.Node_WebRequest_Body}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RequestBody, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,0"
                             Tag="{}{&quot;key&quot;: &quot;value&quot;}"
                             MinHeight="50" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ ClipboardNode — Буфер обмена (Text / Image) ═══════════════ -->
            <DataTemplate DataType="{x:Type nodes:ClipboardNode}">
                <StackPanel>

                    <!-- ТИП ДАННЫХ -->
                    <TextBlock Text="{x:Static res:Strings.Node_ClipboardDataType}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:ClipboardNode.AllDataTypes}}"
                              SelectedItem="{Binding SelectedDataType}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- ТИП ДЕЙСТВИЯ + [?] -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_ClipboardAction}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="УПРАВЛЕНИЕ БУФЕРОМ ОБМЕНА"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Позволяет копировать, читать или записывать тексты и изображения в системный буфер Windows."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Принимает текст или путь к файлу картинки для записи в буфер Windows."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт считанный текст или путь к сохранённой на диске картинке (temp_clip.png) дальше по серебряному проводу."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>

                    <!-- ComboBox текстовых действий — видим при SelectedDataType == Text -->
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:ClipboardNode.AllActionTypes}}"
                              SelectedItem="{Binding ActionType}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDataType}"
                                                 Value="{x:Static nodes:ClipboardDataType.Image}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- ComboBox графических действий — видим при SelectedDataType == Image -->
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:ClipboardNode.AllImageActions}}"
                              SelectedItem="{Binding SelectedImageAction}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDataType}"
                                                 Value="{x:Static nodes:ClipboardDataType.Image}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Поле ввода текста — видно только при Text + WriteText -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding SelectedDataType}"
                                                       Value="{x:Static nodes:ClipboardDataType.Text}"/>
                                            <Condition Binding="{Binding ActionType}"
                                                       Value="{x:Static nodes:ClipboardActionType.WriteText}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Node_ClipboardTextToWrite}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                                <Button.ToolTip>
                                    <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                        <StackPanel MaxWidth="300">
                                            <TextBlock Text="ТЕКСТ ДЛЯ ЗАПИСИ В БУФЕР"
                                                       Foreground="#FFF5D77F" FontFamily="Consolas"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <TextBlock Text="Введите текст для записи в буфер обмена. Также принимает входные данные по серебряному проводу данных."
                                                       Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                        <TextBox Text="{Binding TextToWrite, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"
                                 Tag="Введите текст для записи..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinLines="2" MaxLines="6"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:TextConditionNode}">
                <StackPanel>
                    <!-- ПРОВЕРЯЕМЫЙ ТЕКСТ — readonly, показывает InputValue в реальном времени -->
                    <TextBlock Text="ПРОВЕРЯЕМЫЙ ТЕКСТ:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,10">
                        <TextBox Text="{Binding InputValue, Mode=OneWay}"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="#F2121212"
                                 Foreground="#FFA0A0A0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 MinHeight="50"
                                 AcceptsReturn="True"
                                 IsTabStop="False"
                                 Padding="4"
                                 Tag="Ожидание входящих данных по серебряному проводу..."/>
                        <!-- Placeholder — скрыт когда InputValue не пустой -->
                        <TextBlock Text="Ожидание входящих данных по серебряному проводу..."
                                   FontFamily="Consolas" FontSize="10"
                                   Foreground="#FF3A3A3A"
                                   VerticalAlignment="Top"
                                   Margin="6,5,0,0"
                                   IsHitTestVisible="False"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InputValue}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Пропустить по входным данным (транзитный режим) -->
                    <CheckBox Content="ПРОПУСТИТЬ ПО ВХОДНЫМ ДАННЫМ"
                              IsChecked="{Binding TransitOnInput, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,10"/>

                    <!-- ТИП СРАВНЕНИЯ + [?] -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_TextCompareType}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ТЕКСТОВОЕ УСЛОВИЕ И ТРАНЗИТ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Сравнивает входящий текст с заданным условием и направляет выполнение по золотой (успех) или рубиновой (ошибка) ветке. При успехе транзитом пробрасывает проверенный текст дальше по серебряному проводу."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВХОД:   " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Принимает текст для проверки через серебряный провод. Если провод не подключён — читает из буфера обмена."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВЫХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="При успешном условии передаёт проверенное значение дальше по серебряному проводу."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ТРАНЗИТ:" Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text=" Если включён флаг «ПРОПУСТИТЬ ПО ВХОДНЫМ ДАННЫМ» — нода пропускает сравнение. Если входящий текст не пуст → успех + транзит. Если пуст → ожидание."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:TextConditionNode.AllCompareTypes}}"
                              SelectedItem="{Binding CompareType}"
                              Style="{StaticResource ObsidianComboBoxStyle}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F"
                                               Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- ОБРАЗЕЦ: скрыт при Between и IsEmpty -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompareType}" Value="{x:Static nodes:TextCompareType.Between}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CompareType}" Value="{x:Static nodes:TextCompareType.IsEmpty}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_TextMatchValue}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MatchValue, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,10"/>
                    </StackPanel>

                    <!-- ОТ / ДО: только при Between -->
                    <Grid Margin="0,0,0,10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompareType}" Value="{x:Static nodes:TextCompareType.Between}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Static res:Strings.Node_TextCondition_Min}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#FFF5D77F"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{x:Static res:Strings.Node_TextCondition_Max}" Foreground="#FF888888"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#FFF5D77F"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="{x:Static res:Strings.Node_TextIgnoreCase}"
                              IsChecked="{Binding IgnoreCase}"
                              Foreground="#FFE0E0E0" Margin="0,0,0,8"/>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9"/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ OBS Studio — 5 динамических менеджеров ════════════════════ -->

            <!-- OBS_SceneManagerNode -->
            <DataTemplate DataType="{x:Type obsNodes:OBS_SceneManagerNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_ObsSceneMode}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_SceneManagerNode.AllModes}}"
                              SelectedItem="{Binding SelectedMode}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsSceneName}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableObsScenes, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SceneName, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F" Margin="0,0,0,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{x:Static res:Strings.Node_ObsDisconnectedHint}" Foreground="#FF666666" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <!-- OBS_SourceVisibilityManagerNode — каскад Сцена → Источник → Фильтр -->
            <DataTemplate DataType="{x:Type obsNodes:OBS_SourceVisibilityManagerNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_ObsSceneMode}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_SourceVisibilityManagerNode.AllModes}}"
                              SelectedItem="{Binding SelectedMode}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsTargetType}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_SourceVisibilityManagerNode.AllTargets}}"
                              SelectedItem="{Binding TargetType}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsVisibilityAction}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_SourceVisibilityManagerNode.AllActions}}"
                              SelectedItem="{Binding VisibilityAction}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsSourceScene}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableObsScenes, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SelectedScene}"
                              IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsSource}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableSources, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SelectedSource}"
                              IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Фильтр — только когда TargetType=Filter -->
                    <StackPanel Margin="0,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding TargetType}" Value="Filter"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_ObsFilter}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding DataContext.AvailableFilters, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  SelectedItem="{Binding SelectedFilter}"
                                  IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  Foreground="#FFF5D77F" Margin="0,0,0,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsDisconnectedHint}" Foreground="#FF666666" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <!-- OBS_AudioManagerNode — динамический список аудиовходов -->
            <DataTemplate DataType="{x:Type obsNodes:OBS_AudioManagerNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_ObsSceneMode}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_AudioManagerNode.AllModes}}"
                              SelectedItem="{Binding SelectedMode}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsAudioAction}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_AudioManagerNode.AllAudioActions}}"
                              SelectedItem="{Binding AudioAction}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsAudioInput}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableAudioSources, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SelectedInput}"
                              IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Громкость — только когда AudioAction=SetVolume -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding AudioAction}" Value="SetVolume"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_ObsTargetVolumeDb}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TargetVolumeDb, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F" Margin="0,0,0,6"/>
                    </StackPanel>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsDisconnectedHint}" Foreground="#FF666666" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <!-- OBS_StreamAndRecordManagerNode -->
            <DataTemplate DataType="{x:Type obsNodes:OBS_StreamAndRecordManagerNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_ObsSceneMode}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_StreamAndRecordManagerNode.AllModes}}"
                              SelectedItem="{Binding SelectedMode}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsStreamTarget}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_StreamAndRecordManagerNode.AllTargets}}"
                              SelectedItem="{Binding StreamTarget}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsStreamAction}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_StreamAndRecordManagerNode.AllActions}}"
                              SelectedItem="{Binding StreamAction}" Foreground="#FFF5D77F" Margin="0,0,0,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsDisconnectedHint}" Foreground="#FF666666" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <!-- OBS_DynamicContentManagerNode — каскад Сцена → Источник + переключение типа -->
            <DataTemplate DataType="{x:Type obsNodes:OBS_DynamicContentManagerNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_ObsSceneMode}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_DynamicContentManagerNode.AllModes}}"
                              SelectedItem="{Binding SelectedMode}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsContentType}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_DynamicContentManagerNode.AllContentTypes}}"
                              SelectedItem="{Binding ContentType}" Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsSourceScene}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableObsScenes, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SelectedScene}"
                              IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsSource}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableSources, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SelectedSource}"
                              IsEnabled="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Текст — только когда ContentType=Text -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding ContentType}" Value="Text"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_ObsTextContent}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TextContent, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="80" Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- Путь к файлу — когда ContentType=Image или Media -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContentType}" Value="Image"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ContentType}" Value="Media"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_ObsFilePath}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- Действие медиа — только когда ContentType=Media -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding ContentType}" Value="Media"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_ObsMediaAction}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Source={x:Static obsNodes:OBS_DynamicContentManagerNode.AllMediaActions}}"
                                  SelectedItem="{Binding MediaAction}" Foreground="#FFF5D77F" Margin="0,0,0,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="{x:Static res:Strings.Node_ObsDisconnectedHint}" Foreground="#FF666666" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsObsConnected, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <!-- ══ СИСТЕМА — Windows-ноды (заглушки) ════════════════════════ -->

            <DataTemplate DataType="{x:Type nodes:Win_ProcessManagerNode}">
                <StackPanel>
                    <!-- ВХОДНЫЕ ДАННЫЕ ПРОЦЕССА: Border+TextBlock — без наложений -->
                    <TextBlock Text="ВХОДНЫЕ ДАННЫЕ ПРОЦЕССА:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <Border Background="#F2121212" BorderBrush="#FF2A2A2A" BorderThickness="1"
                            CornerRadius="4" Padding="6,4" MinHeight="36" Margin="0,0,0,4">
                        <Grid>
                            <TextBlock Text="{Binding InputValue}"
                                       Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputValue}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Ожидание входящего процесса по серебряному проводу..."
                                       Foreground="#FF3A3A3A" FontFamily="Consolas" FontSize="10"
                                       TextWrapping="Wrap" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputValue}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Обрабатывать присланный процесс -->
                    <CheckBox Content="Обрабатывать присланный процесс"
                              IsChecked="{Binding ProcessInputData, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,10"/>

                    <!-- Тип действия -->
                    <TextBlock Text="ТИП ДЕЙСТВИЯ:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:Win_ProcessManagerNode.AllActions}}"
                              SelectedItem="{Binding SelectedAction}"
                              Style="{StaticResource ObsidianComboBoxStyle}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F"
                                               Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Выбор из активных процессов -->
                    <TextBlock Text="ВЫБРАТЬ ИЗ АКТИВНЫХ:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.ActiveSystemProcesses,
                                                   RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding DataContext.SelectedActiveProcess,
                                                     RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Style="{StaticResource ObsidianComboBoxStyle}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0"
                                           Source="{Binding Icon}"
                                           Width="16" Height="16" Margin="0,0,8,0"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1" ClipToBounds="True" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProcessName}"
                                                   Foreground="#FFF5D77F"
                                                   Style="{StaticResource MarqueeTextBlockStyle}"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Список процессов + [?] -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="СПИСОК ПРОЦЕССОВ:" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource ObsidianHelpButtonStyle}"
                                Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="УПРАВЛЕНИЕ ПРОЦЕССАМИ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Позволяет принудительно закрывать (убивать), перезапускать или проверять активность запущенных в системе программ. Можно указать несколько процессов — список расширяется автоматически."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Принимает имя процесса через серебряный провод. При включённом флаге «Обрабатывать присланный процесс» — нода обрабатывает оба: список и входящий."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,8">
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт имя первого успешно обработанного процесса (например, chrome.exe) дальше по серебряному проводу."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Text="Расширение .exe вводить необязательно."
                                                   Foreground="#FF666666"
                                                   FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ProcessesList}" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="#FFF5D77F"
                                         Tag="Введите имя процесса (например, chrome)..."
                                         Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Оптимизатор передачи данных — внизу -->
                    <CheckBox Content="Разрешить передачу данных по серебряному проводу"
                              IsChecked="{Binding IsDataOutputEnabled, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:Win_WindowManagerNode}">
                <StackPanel>
                    <!-- Оптимизатор передачи данных — наверху -->
                    <CheckBox Content="Разрешить передачу данных по серебряному проводу"
                              IsChecked="{Binding IsDataOutputEnabled, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,10"/>

                    <!-- ВХОДНЫЕ ДАННЫЕ ПРОЦЕССА: Border+TextBlock — без наложений -->
                    <TextBlock Text="ВХОДНЫЕ ДАННЫЕ ПРОЦЕССА:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <Border Background="#F2121212" BorderBrush="#FF2A2A2A" BorderThickness="1"
                            CornerRadius="4" Padding="6,4" MinHeight="36" Margin="0,0,0,4">
                        <Grid>
                            <TextBlock Text="{Binding InputValue}"
                                       Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputValue}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Ожидание входящего процесса по серебряному проводу..."
                                       Foreground="#FF3A3A3A" FontFamily="Consolas" FontSize="10"
                                       TextWrapping="Wrap" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputValue}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Обрабатывать присланный процесс -->
                    <CheckBox Content="Обрабатывать присланный процесс"
                              IsChecked="{Binding ProcessInputData, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,10"/>

                    <!-- ОКНО ПРОЦЕССА: выпадающий список активных + ручной ввод -->
                    <TextBlock Text="ОКНО ПРОЦЕССА:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.ActiveSystemProcesses,
                                                   RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding DataContext.SelectedActiveProcess,
                                                     RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              Style="{StaticResource ObsidianComboBoxStyle}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0"
                                           Source="{Binding Icon}"
                                           Width="16" Height="16" Margin="0,0,8,0"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1" ClipToBounds="True" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProcessName}"
                                                   Foreground="#FFF5D77F"
                                                   Style="{StaticResource MarqueeTextBlockStyle}"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- Список процессов — скрыт в режиме "Все окна" -->
                    <ItemsControl ItemsSource="{Binding ProcessesList}" Margin="0,0,0,10">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAllWindowsMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="#FFF5D77F"
                                         Tag="Введите имя процесса (например, Telegram)..."
                                         Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ДЕЙСТВИЕ НАД ОКНОМ + [?] -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ДЕЙСТВИЕ НАД ОКНОМ:" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="УПРАВЛЕНИЕ ОКНАМИ"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Позволяет менять состояние, размеры и положение окон процессов. В режиме «Все окна» выполняет системные операции (свернуть/восстановить/сетка)."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Принимает имя процесса через серебряный провод. При включённом флаге «Обрабатывать присланный процесс» — нода обрабатывает оба: ручной и входящий."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,8">
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Передаёт имя первого успешно обработанного процесса (например, Telegram.exe) дальше по серебряному проводу."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock Text="Расширение .exe вводить необязательно."
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </Grid>
                    <!-- ComboBox действий: ItemsSource переключается по IsAllWindowsMode -->
                    <ComboBox SelectedItem="{Binding SelectedAction}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,10">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource ObsidianComboBoxStyle}">
                                <Setter Property="ItemsSource"
                                        Value="{Binding Source={x:Static nodes:Win_WindowManagerNode.SingleWindowActions}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAllWindowsMode}" Value="True">
                                        <Setter Property="ItemsSource"
                                                Value="{Binding Source={x:Static nodes:Win_WindowManagerNode.AllWindowsActions}}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F"
                                               Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Координаты — видимы только при MoveAndResize -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAction}"
                                                 Value="{x:Static nodes:WinWindowAction.MoveAndResize}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ШИРИНА" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ВЫСОТА" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:Win_SystemPowerNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_Power_Action}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:Win_SystemPowerNode.AllActions}}"
                              SelectedItem="{Binding SelectedAction}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F"
                                               Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:Win_PowerShellNode}">
                <StackPanel>
                    <!-- ВХОДНЫЕ ДАННЫЕ СЦЕНАРИЯ: Border+TextBlock — без наложений -->
                    <TextBlock Text="ВХОДНЫЕ ДАННЫЕ СЦЕНАРИЯ:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <Border Background="#F2121212" BorderBrush="#FF2A2A2A" BorderThickness="1"
                            CornerRadius="4" Padding="6,4" MinHeight="36" Margin="0,0,0,4">
                        <Grid>
                            <TextBlock Text="{Binding InputValue}"
                                       Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputValue}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Ожидание входящего сценария по серебряному проводу..."
                                       Foreground="#FF3A3A3A" FontFamily="Consolas" FontSize="10"
                                       TextWrapping="Wrap" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputValue}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Обрабатывать присланный сценарий -->
                    <CheckBox Content="Обрабатывать присланный сценарий"
                              IsChecked="{Binding ProcessInputData, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,10"/>

                    <!-- Переключатель PowerShell / CMD -->
                    <CheckBox IsChecked="{Binding IsPowerShell}"
                              Content="{x:Static res:Strings.Node_PowerShell_UsePwsh}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,10"/>

                    <!-- Сценарий + [?] -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="СЦЕНАРИЙ:" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource ObsidianHelpButtonStyle}"
                                Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="400">
                                        <TextBlock Text="ПРИМЕРЫ СЦЕНАРИЕВ POWERSHELL"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="1. Загрузка процессора (%):"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="$cpu = Get-Counter '\Processor(_Total)\% Processor Time' | Select-Object -ExpandProperty CounterSamples | Select-Object -ExpandProperty CookedValue; Write-Output &quot;CPU: $([Math]::Round($cpu, 1))%&quot;"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="2. Свободное место на C: (ГБ):"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="$drive = Get-PSDrive C | Select-Object -ExpandProperty Free; $gb = [Math]::Round($drive / 1GB, 2); Write-Output &quot;Disk C: $gb GB free&quot;"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="3. Время по Гринвичу (UTC):"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="(Get-Date).ToUniversalTime().ToString(&quot;yyyy-MM-dd HH:mm:ss UTC&quot;)"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="4. Лаконичная погода:"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="Invoke-RestMethod -Uri &quot;http://wttr.in/?format=3&quot;"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="5. Твой публичный IP:"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="Invoke-RestMethod -Uri &quot;https://api.ipify.org&quot;"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="6. Случайный пароль (12 симв.):"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="$chars = &quot;abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%&quot;; $pass = -join ((1..12) | ForEach-Object { $chars[(Get-Random -Maximum $chars.Length)] }); Write-Output $pass"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="7. Уникальный ID (GUID):"
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="[guid]::NewGuid().ToString()"
                                                   Foreground="#FF666666" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </Grid>
                    <TextBox Text="{Binding ScriptText, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="120"/>

                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="Разрешить передачу данных по серебряному проводу"
                              IsChecked="{Binding IsDataOutputEnabled, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,8,0,6"/>

                    <!-- Вывод консоли (только чтение) -->
                    <TextBlock Text="ВЫВОД КОНСОЛИ:" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,2,0,4"/>
                    <TextBox Text="{Binding ConsoleOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="#F2121212"
                             Foreground="#FFA0A0A0"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextWrapping="Wrap"
                             MinHeight="60"
                             AcceptsReturn="True"
                             IsTabStop="False"
                             Margin="0,0,0,10"
                             Tag="Ожидание выполнения скрипта для вывода в консоль..."/>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:Win_AudioDeviceNode}">
                <StackPanel>
                    <CheckBox IsChecked="{Binding IsPlayback}"
                              Content="{x:Static res:Strings.Node_AudioDevice_IsPlayback}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{x:Static res:Strings.Node_AudioDevice_Name}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ УМНАЯ ЛОГИКА ══════════════════════════════════════════ -->

            <DataTemplate DataType="{x:Type nodes:Wait_SmartDelayNode}">
                <StackPanel>
                    <!-- Тип ожидания -->
                    <TextBlock Text="{x:Static res:Strings.Node_SmartWait_WaitType}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static nodes:Wait_SmartDelayNode.AllWaitTypes}}"
                              SelectedItem="{Binding WaitType}"
                              Foreground="#FFF5D77F"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F"
                                               Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Таймаут -->
                    <TextBlock Text="{x:Static res:Strings.Node_SmartWait_Timeout}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TimeoutSec, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,8"/>

                    <!-- Режим UntilWindowActive: поле имени процесса -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WaitType}" Value="{x:Static nodes:SmartWaitType.UntilPixelColor}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_SmartWait_Window}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding WindowProcessName, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"/>
                    </StackPanel>

                    <!-- Режим UntilPixelColor: X, Y, цвет -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WaitType}" Value="{x:Static nodes:SmartWaitType.UntilPixelColor}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static res:Strings.Node_SmartWait_PixelX}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static res:Strings.Node_SmartWait_PixelY}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{x:Static res:Strings.Node_SmartWait_Color}" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TargetColorHex, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF5D77F"/>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type nodes:Logic_CounterNode}">
                <StackPanel>
                    <TextBlock Text="Лимит" Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Limit, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,8"/>
                    <!-- Оптимизатор передачи данных -->
                    <CheckBox Content="ПЕРЕДАВАТЬ ДАННЫЕ" IsChecked="{Binding IsDataOutputEnabled}"
                              Foreground="#FF888888" FontFamily="Consolas" FontSize="9"/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Logic_BranchNode — Ветвление условий ══════════════════════ -->
            <DataTemplate DataType="{x:Type nodes:Logic_BranchNode}">
                <StackPanel>
                    <!-- Тип данных -->
                    <TextBlock Text="{x:Static res:Strings.Node_Branch_DataType}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{x:Static nodes:Logic_BranchNode.AllDataTypes}"
                              SelectedItem="{Binding DataType}"
                              Style="{StaticResource ObsidianComboBoxStyle}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Тип сравнения -->
                    <TextBlock Text="{x:Static res:Strings.Node_Branch_CompareType}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>

                    <!-- ComboBox для Text и Boolean (без > и <) -->
                    <ComboBox ItemsSource="{x:Static nodes:Logic_BranchNode.TextBoolCompareTypes}"
                              SelectedItem="{Binding CompareType}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource ObsidianComboBoxStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataType}" Value="{x:Static nodes:LogicDataType.Number}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- ComboBox для Number (включая > и <) -->
                    <ComboBox ItemsSource="{x:Static nodes:Logic_BranchNode.NumberCompareTypes}"
                              SelectedItem="{Binding CompareType}"
                              Foreground="#FFF5D77F" Margin="0,0,0,10">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource ObsidianComboBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataType}" Value="{x:Static nodes:LogicDataType.Number}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumToLocalizedDescriptionConverter}}"
                                               Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Эталонное значение -->
                    <TextBlock Text="{x:Static res:Strings.Node_Branch_TargetValue}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,10"/>

                    <!-- Игнорировать регистр — только для Text -->
                    <CheckBox Content="{x:Static res:Strings.Node_Branch_IgnoreCase}"
                              IsChecked="{Binding IgnoreCase}"
                              Foreground="#FFE0E0E0">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataType}" Value="{x:Static nodes:LogicDataType.Text}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Logic_QueueBlockNode — Блок Очереди ════════════════════════ -->
            <DataTemplate DataType="{x:Type nodes:Logic_QueueBlockNode}">
                <StackPanel>
                    <!-- Флаг: дождаться всей цепочки -->
                    <CheckBox Content="{x:Static res:Strings.Node_QueueBlock_WaitFullChain}"
                              IsChecked="{Binding WaitFullChain}"
                              Foreground="#FFE0E0E0" Margin="0,0,0,10"/>

                    <!-- Счётчик нод: показывается только при WaitFullChain=false -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WaitFullChain}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.Node_QueueBlock_WaitNodesCount}"
                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding WaitNodesCount, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="#FFF5D77F"/>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Win_BypassQueueNode — Приоритетный запуск ══════════════════════ -->
            <DataTemplate DataType="{x:Type nodes:Win_BypassQueueNode}">
                <StackPanel>
                    <!-- Заголовок + [?] ToolTip -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                        <TextBlock Text="ВНЕ ОЧЕРЕДИ"
                                   Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="ВНЕ ОЧЕРЕДИ"
                                                   Foreground="#FFF5D77F"
                                                   FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                            <Run Text="Управляет уровнем приоритета макроса в планировщике. Без флагов — макрос обходит очереди регионов, но уважает монополию."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="Системный уровень (IgnoreAllRestrictions): "
                                                 Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Запуск мгновенный, обходит всё: очереди, монополию и условия среды. Не может быть остановлен блокировкой другого макроса."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="Монопольный режим (BlockOthersOnExecution): "
                                                 Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Ждёт освобождения от System Level и других монополистов, затем замораживает запуск всех остальных макросов до своего завершения."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>

                    <!-- Чекбокс 1: IgnoreAllRestrictions (System Level) -->
                    <CheckBox Content="Системный уровень: игнорировать все ограничения"
                              IsChecked="{Binding IgnoreAllRestrictions, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"
                              Margin="0,0,0,8"/>

                    <!-- Чекбокс 2: BlockOthersOnExecution (Exclusive) -->
                    <CheckBox Content="Монопольный режим: блокировать другие макросы"
                              IsChecked="{Binding BlockOthersOnExecution, Mode=TwoWay}"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Foreground="#FFF5D77F"
                              FontFamily="Consolas" FontSize="9"/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Logic_SequenceNode — Очередь действий ═══════════════════════ -->
            <DataTemplate DataType="{x:Type nodes:Logic_SequenceNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_Sequence_StepsLabel}"
                               Foreground="#FF888888" FontFamily="Consolas" FontSize="9" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="6,4"
                                        Background="#0AD4AF37" CornerRadius="3"
                                        BorderBrush="#22D4AF37" BorderThickness="1">
                                    <StackPanel>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Foreground="#FFF5D77F" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                                                     ToolTip="Успех: не подключён">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#FF2A2A2A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSuccessConnected}" Value="True">
                                                                <Setter Property="Fill" Value="#FFD4AF37"/>
                                                                <Setter Property="ToolTip" Value="Успех: подключён"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                                                     ToolTip="Данные: не подключены">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#FF2A2A2A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDataConnected}" Value="True">
                                                                <Setter Property="Fill" Value="#FFB8B8B8"/>
                                                                <Setter Property="ToolTip" Value="Данные: подключены"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Ellipse Width="8" Height="8"
                                                     ToolTip="Ошибка: не подключена">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#FF2A2A2A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsErrorConnected}" Value="True">
                                                                <Setter Property="Fill" Value="#FF8B0000"/>
                                                                <Setter Property="ToolTip" Value="Ошибка: подключена"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DataTemplate>

            <!-- ══ ИНТЕРФЕЙС И HUD — Win_SpeakTextNode ══════════════════════ -->

            <DataTemplate DataType="{x:Type nodes:Win_SpeakTextNode}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Node_SpeakText}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TextToSpeak, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"
                             TextWrapping="Wrap" AcceptsReturn="False" MaxLines="3"
                             Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static res:Strings.Node_SpeakVoice}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableVoices, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                              SelectedItem="{Binding SelectedVoice}"
                              Foreground="#FFF5D77F" Margin="0,0,0,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><Grid ClipToBounds="True"><TextBlock Text="{Binding}" Foreground="#FFF5D77F" Style="{StaticResource MarqueeTextBlockStyle}"/></Grid></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.Node_SpeakTtsDisabledHint}"
                               Foreground="#FFFF3B30" FontFamily="Consolas" FontSize="9"
                               TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsTtsDisabled, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Vision_OcrNode — OCR: Распознавание текста ══════════════ -->
            <DataTemplate DataType="{x:Type nodes:Vision_OcrNode}">
                <StackPanel>
                    <!-- ПУТЬ К ИЗОБРАЖЕНИЮ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_OcrImagePath}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="OCR: РАСПОЗНАВАНИЕ ТЕКСТА"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Распознаёт текст на изображении через встроенный Windows OCR. Не требует интернета или сторонних библиотек."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Путь к PNG/JPG файлу. Принимает данные из ноды «Буфер обмена» (режим ReadImage) через серебряный провод."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Распознанный текст в виде строки → серебряный провод данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox Text="{Binding ImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,10"/>
                    <!-- ЯЗЫК OCR -->
                    <TextBlock Text="{x:Static res:Strings.Node_OcrLanguage}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding LanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,10"/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Win_TranslateNode — Перевод текста (Google API) ══════════ -->
            <DataTemplate DataType="{x:Type nodes:Win_TranslateNode}">
                <StackPanel>
                    <!-- ЦЕЛЕВОЙ ЯЗЫК -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Node_WinTranslateTargetCode}" Foreground="#FF888888"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ObsidianHelpButtonStyle}" Margin="6,0,0,0">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ObsidianToolTipStyle}">
                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="КОД ЯЗЫКА ПЕРЕВОДА"
                                                   Foreground="#FFF5D77F" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Двухбуквенный системный код языка, на который нужно перевести текст."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Text="Примеры: ru — русский, en — английский, de — немецкий, fr — французский, ja — японский."
                                                   Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="ВХОД:  " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Исходный текст. Принимает данные из ноды «OCR» или «Буфер обмена» через серебряный провод."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="ВЫХОД: " Foreground="#FFF5D77F" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            <Run Text="Переведённый текст → серебряный провод данных."
                                                 Foreground="#FFA0A0A0" FontFamily="Consolas" FontSize="9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <TextBox Text="{Binding TargetLanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" Margin="0,0,0,10"/>
                    <!-- ИСХОДНЫЙ ТЕКСТ -->
                    <TextBlock Text="{x:Static res:Strings.Node_WinTranslateSourceText}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SourceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F" AcceptsReturn="True" Height="60"
                             TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <!-- РЕЗУЛЬТАТ ПЕРЕВОДА -->
                    <TextBlock Text="{x:Static res:Strings.Node_WinTranslateResult}" Foreground="#FF888888"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TranslatedText, Mode=TwoWay}"
                             IsReadOnly="True" AcceptsReturn="True" MinHeight="60"
                             Foreground="#FFF5D77F" TextWrapping="Wrap" Margin="0,0,0,4"
                             Tag="Здесь отобразится готовый перевод после выполнения..."/>
                </StackPanel>
            </DataTemplate>

            <!-- ══ Стиль кнопки-переключателя панели ════════════════════════
                 Узкая вертикальная полоска на границе панель/холст.
                 Obsidian-фон + золотое свечение при наведении.               -->
            <Style x:Key="PanelToggleStyle" TargetType="ToggleButton">
                <Setter Property="Focusable"        Value="False"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="Width"            Value="14"/>
                <Setter Property="Height"           Value="56"/>
                <Setter Property="Panel.ZIndex"     Value="20"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Root"
                                    Background="#66121212"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#AA1E1E1E"/>
                                    <Setter TargetName="Root" Property="Effect"     Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#44D4AF37"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked"   Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Root" Property="Background" Value="#88D4AF37"/>
                                    <Setter TargetName="Root" Property="Effect"     Value="{StaticResource GoldGlowEffect}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ══ Корневая сетка: [Auto:Toolbox] [*:Canvas] [Auto:Props] ══════════
         Колонки Auto: ширина определяется контентом (Border с анимируемым Width).
         При схлопывании Border до 0 → колонка становится 0 → Canvas растягивается.  -->
    <Grid x:Name="RootGrid">
        <!-- OpacityMask обрезает содержимое по скруглённым углам внешнего окна (CornerRadius="9"):
             WPF ClipToBounds не учитывает CornerRadius — маска единственный надёжный способ. -->
        <Grid.OpacityMask>
            <VisualBrush Stretch="None">
                <VisualBrush.Visual>
                    <Border Background="Black"
                            Width="{Binding ActualWidth, ElementName=RootGrid}"
                            Height="{Binding ActualHeight, ElementName=RootGrid}"
                            CornerRadius="9"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.OpacityMask>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             Колонка 0: Toolbox  (схлопывается до Width=0 при IsChecked=True)
        ═══════════════════════════════════════════════════════════════════════ -->
        <Border x:Name="ToolboxBorder"
                Grid.Column="0"
                Width="220"
                MinWidth="0"
                ClipToBounds="True"
                Background="#FF0F0F0F">

            <DockPanel>

                <!-- Заголовок -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding ToolboxTitle}"
                           Foreground="{StaticResource GoldBrush}"
                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                           Margin="12,10,12,0"/>

                <Rectangle DockPanel.Dock="Top"
                           Height="1" Fill="#FF2A2A2A"
                           Margin="8,8,8,6"/>

                <!-- Подсказка снизу -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding ToolboxDragHint}"
                           Foreground="#FF383838"
                           FontFamily="Segoe UI" FontSize="9"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="10,6,10,10"/>

                <!-- Список шаблонов нод, сгруппированных по CategoryName -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              FocusVisualStyle="{x:Null}">
                <ItemsControl x:Name="ToolboxList"
                              ItemsSource="{Binding NodeTemplatesView}"
                              Background="Transparent">

                    <!-- ══ Группы-спойлеры (Expander) в стиле Obsidian Gold ══ -->
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <StackPanel>

                                                    <!-- Заголовок категории: кликабельный Toggle с анимированным шевроном -->
                                                    <ToggleButton x:Name="Toggle"
                                                                  IsChecked="True"
                                                                  Focusable="False"
                                                                  FocusVisualStyle="{x:Null}"
                                                                  Cursor="Hand">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border BorderBrush="{StaticResource GoldBrush}"
                                                                        BorderThickness="0,1,0,0"
                                                                        Background="Transparent"
                                                                        Padding="8,6,8,6"
                                                                        SnapsToDevicePixels="True">
                                                                    <Grid>
                                                                        <!-- Название категории в верхнем регистре -->
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="{StaticResource GoldBrush}"
                                                                                   FontFamily="Segoe UI"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="11"
                                                                                   VerticalAlignment="Center"/>

                                                                        <!-- Золотой шеврон: ∨ → вращается 180° при раскрытии -->
                                                                        <Path x:Name="Chevron"
                                                                              HorizontalAlignment="Right"
                                                                              VerticalAlignment="Center"
                                                                              Data="M0,3 L5,7 L10,3"
                                                                              Stroke="{StaticResource GoldBrush}"
                                                                              StrokeThickness="1.5"
                                                                              Fill="Transparent"
                                                                              StrokeLineJoin="Round"
                                                                              StrokeStartLineCap="Round"
                                                                              StrokeEndLineCap="Round"
                                                                              RenderTransformOrigin="0.5,0.5">
                                                                            <Path.RenderTransform>
                                                                                <RotateTransform Angle="180"/>
                                                                            </Path.RenderTransform>
                                                                        </Path>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <!-- IsChecked=True → раскрыто: шеврон ↑ (180°) -->
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Trigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetName="Chevron"
                                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                        To="180" Duration="0:0:0.2"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.EnterActions>
                                                                        <!-- IsChecked=False → свёрнуто: шеврон ↓ (0°) -->
                                                                        <Trigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetName="Chevron"
                                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                        To="0" Duration="0:0:0.2"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.ExitActions>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>

                                                    <!-- Содержимое группы: ноды этой категории -->
                                                    <ItemsPresenter x:Name="Items" Margin="0,2,0,4"/>

                                                </StackPanel>
                                                <!-- Collapse-триггер: скрываем ноды при IsChecked=False -->
                                                <ControlTemplate.Triggers>
                                                    <Trigger SourceName="Toggle" Property="IsChecked" Value="False">
                                                        <Setter TargetName="Items" Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6,3" Padding="10,9"
                                    CornerRadius="5" Cursor="SizeAll"
                                    ToolTip="{Binding Description}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"      Value="#FF1A1A1A"/>
                                        <Setter Property="BorderBrush"     Value="#FF2A2A2A"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#FFD4AF37"/>
                                                <Setter Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Viewbox Grid.Column="0" Width="16" Height="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Path Data="{Binding IconGeometry}"
                                              Fill="{StaticResource GoldBrush}"
                                              Stretch="Fill"
                                              SnapsToDevicePixels="True"/>
                                    </Viewbox>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Foreground="#FFE0E0E0"
                                               FontFamily="Segoe UI" FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="7,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             Колонка 1: Blueprint Canvas + плавающие кнопки-переключатели
        ═══════════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Blueprint-холст -->
            <AdornerDecorator Panel.ZIndex="0">
            <ScrollViewer x:Name="CanvasScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#FF0D0D0D"
                          PanningMode="None"
                          Margin="0,12,4,0">

                <Canvas x:Name="EditorCanvas"
                        Width="3000" Height="2000"
                        AllowDrop="True"
                        SnapsToDevicePixels="True">

                    <Canvas.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,30,30"
                                      ViewportUnits="Absolute"
                                      Stretch="None">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#FF0D0D0D">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,30,30"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#FF191919" Thickness="1"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="30,0" EndPoint="30,30"/>
                                                <LineGeometry StartPoint="0,30" EndPoint="30,30"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Canvas.Background>

                    <!-- Слой связей -->
                    <ItemsControl x:Name="ConnectionsControl"
                                  Width="3000" Height="2000"
                                  ItemsSource="{Binding ConnectionLines}"
                                  IsHitTestVisible="True"
                                  Canvas.Left="0" Canvas.Top="0"
                                  Panel.ZIndex="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsItemsHost="True" Background="{x:Null}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:VisualConnectionLine}">
                                <Canvas x:Name="RootCanvas">

                                    <!-- Видимая линия связи -->
                                    <Path x:Name="ConnectionPath"
                                          Data="{Binding BezierPath}"
                                          Fill="Transparent"
                                          StrokeThickness="2"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Canvas.Left="0" Canvas.Top="0">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Stroke" Value="#FFD4AF37"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsErrorRoute}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFD32F2F"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDataRoute}" Value="True">
                                                        <Setter Property="Stroke" Value="{StaticResource SilverDataPortBrush}"/>
                                                    </DataTrigger>
                                                    <!-- Изумрудный провод: триггер → TriggerRootNode -->
                                                    <DataTrigger Binding="{Binding IsTriggerRoute}" Value="True">
                                                        <Setter Property="Stroke"          Value="{StaticResource TriggerWireBrush}"/>
                                                        <Setter Property="StrokeThickness" Value="2"/>
                                                        <Setter Property="Effect"          Value="{StaticResource TriggerWireGlowEffect}"/>
                                                    </DataTrigger>
                                                    <!-- Мятный провод: между блоками очереди -->
                                                    <DataTrigger Binding="{Binding IsQueueLink}" Value="True">
                                                        <Setter Property="Stroke"          Value="{StaticResource QueueWireBrush}"/>
                                                        <Setter Property="StrokeThickness" Value="2"/>
                                                        <Setter Property="Effect"          Value="{StaticResource QueueWireGlowEffect}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>

                                </Canvas>

                                <DataTemplate.Triggers>
                                    <!-- Бегущий пунктир при активном исполнении -->
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="ConnectionPath" Property="StrokeThickness" Value="2.5"/>
                                        <Setter TargetName="ConnectionPath" Property="StrokeDashArray">
                                            <Setter.Value>
                                                <DoubleCollection>5 5</DoubleCollection>
                                            </Setter.Value>
                                        </Setter>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="DashSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="ConnectionPath"
                                                                     Storyboard.TargetProperty="StrokeDashOffset"
                                                                     From="10" To="0" Duration="0:0:0.4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="DashSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Слой карточек нод -->
                    <ItemsControl x:Name="NodesControl"
                                  Width="3000" Height="2000"
                                  ItemsSource="{Binding VisualNodes}"
                                  IsHitTestVisible="True"
                                  Canvas.Left="0" Canvas.Top="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsItemsHost="True" Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.Resources>
                            <DataTemplate x:Key="NodeCardDefaultTemplate" DataType="{x:Type models:VisualNode}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Порт In -->
                                    <Ellipse Grid.Column="0" Tag="In"
                                             Width="12" Height="12"
                                             Fill="#FF3A3A3A" Stroke="#FF888888"
                                             StrokeThickness="1"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             Cursor="Hand" ToolTip="{x:Static res:Strings.Blueprint_PortIn}">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Fill"   Value="#FF555555"/>
                                                        <Setter Property="Stroke" Value="#FFD4AF37"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Золотое свечение: Executing / Success -->
                                    <Border x:Name="GoldGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="6"
                                            Background="#33D4AF37"
                                            BorderThickness="0"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="4" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Рубиновое свечение: Failed -->
                                    <Border x:Name="RubyGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="6"
                                            Background="#33CC2222"
                                            BorderThickness="0"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFCC2222" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Тело карточки -->
                                    <Border x:Name="CardBorder"
                                            Grid.Column="1"
                                            Background="#FF1E1E1E"
                                            CornerRadius="6" Padding="10,8"
                                            Cursor="SizeAll"
                                            Tag="{Binding DataContext,
                                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{x:Static res:Strings.Blueprint_NodeCtxSetStart}"
                                                          Command="{Binding PlacementTarget.Tag.SetAsStartNodeCommand,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                                <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>
                                                <MenuItem Header="{x:Static res:Strings.Blueprint_NodeCtxDelete}"
                                                          Command="{Binding PlacementTarget.Tag.DeleteNodeCommand,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Foreground" Value="{StaticResource RubyBrush}"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFFF4444"/>
                                                                    <Setter Property="Effect"     Value="{StaticResource RubyGlowEffect}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush"     Value="#FF2A2A2A"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FFD4AF37"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource GoldBrush}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="9" Margin="0,4,0,0"
                                                       FontFamily="Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF666666"/>
                                                        <Setter Property="Text" Value="{Binding State}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Executing">
                                                                <Setter Property="Foreground" Value="#FFD4AF37"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Success">
                                                                <Setter Property="Foreground" Value="#FF7FBB4A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Failed">
                                                                <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Выходные порты -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Ellipse Tag="Success"
                                                 Width="12" Height="12"
                                                 Fill="#FFD4AF37" Stroke="#FFAA7C11"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,4"
                                                 Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortSuccess}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill"   Value="#FFF5D77F"/>
                                                            <Setter Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Ellipse Tag="Data"
                                                 Width="12" Height="12"
                                                 Fill="#FF2A2A2A" Stroke="{StaticResource SilverDataPortBrush}"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,4"
                                                 Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortData}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill"   Value="#FF444444"/>
                                                            <Setter Property="Stroke" Value="#FFE8E8E8"/>
                                                            <Setter Property="Effect" Value="{StaticResource SilverGlowEffect}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Ellipse Tag="Error"
                                                 Width="12" Height="12"
                                                 Fill="#FF8B0000" Stroke="#FF5A0000"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortError}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill"   Value="{StaticResource RubyBrush}"/>
                                                            <Setter Property="Stroke" Value="{StaticResource RubyBrush}"/>
                                                            <Setter Property="Effect" Value="{StaticResource RubyGlowEffect}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <!-- Hover-свечение карточки: BlurRadius 20→30 за 150 мс -->
                                    <EventTrigger RoutedEvent="Border.MouseEnter" SourceName="CardBorder">
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="30" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.85" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Border.MouseLeave" SourceName="CardBorder">
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="20" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.5" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <!-- IsSelected: BlurRadius 20→30 за 150 мс -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="30" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.85" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="20" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.5" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- Executing: золотое пульсирование 800 мс, бесконечно -->
                                    <DataTrigger Binding="{Binding State}" Value="Executing">
                                        <Setter TargetName="GoldGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="ExecutingSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="GoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="4" To="20" Duration="0:0:0.8"/>
                                                    <DoubleAnimation Storyboard.TargetName="GoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.3" To="0.9" Duration="0:0:0.8"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="ExecutingSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>

                                    <!-- Success: кратная золотая вспышка 500 мс, однократно -->
                                    <DataTrigger Binding="{Binding State}" Value="Success">
                                        <Setter TargetName="GoldGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SuccessSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard FillBehavior="Stop">
                                                    <DoubleAnimation Storyboard.TargetName="GoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="25" To="4" Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="GoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="1.0" To="0.0" Duration="0:0:0.5"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SuccessSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>

                                    <!-- Failed: рубиновое резкое пульсирование 400 мс, бесконечно -->
                                    <DataTrigger Binding="{Binding State}" Value="Failed">
                                        <Setter TargetName="RubyGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="FailedSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="RubyGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="8" To="18" Duration="0:0:0.4"/>
                                                    <DoubleAnimation Storyboard.TargetName="RubyGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.4" To="1.0" Duration="0:0:0.4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="FailedSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>

                            <!-- ══ Карточка TriggerRootNode: точка входа графа ══              -->
                            <!--   Геометрия портов (совпадает с VisualNode.cs):               -->
                            <!--   НЕТ InPort — входящие соединения запрещены в ConnectNodes   -->
                            <!--   Success center = (X+161, Y+27) — VerticalAlignment="Center" -->
                            <DataTemplate x:Key="NodeCardTriggerRootTemplate" DataType="{x:Type models:VisualNode}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Колонка 0: намеренно пуста (нет входного порта) -->

                                    <!-- Постоянное золотое свечение -->
                                    <Border x:Name="RootGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="8"
                                            Background="#22D4AF37"
                                            BorderThickness="0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Тело карточки: ContextMenu="{x:Null}" — запрет контекстного меню -->
                                    <Border x:Name="RootCardBorder"
                                            Grid.Column="1"
                                            Background="#FF1C1400"
                                            CornerRadius="8" Padding="10,8"
                                            Cursor="SizeAll"
                                            ContextMenu="{x:Null}"
                                            Tag="{Binding DataContext,
                                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="28" ShadowDepth="0" Opacity="0.85"/>
                                        </Border.Effect>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush"     Value="#FFD4AF37"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FFF5D77F"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="▶ СТАРТ"
                                                       Foreground="{StaticResource GoldBrush}"
                                                       FontFamily="Consolas" FontSize="9"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#FFF5D77F"
                                                       FontFamily="Consolas" FontSize="8"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="8" Margin="0,3,0,0"
                                                       FontFamily="Consolas"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF666666"/>
                                                        <Setter Property="Text" Value="{Binding State}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Executing">
                                                                <Setter Property="Foreground" Value="#FFD4AF37"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Success">
                                                                <Setter Property="Foreground" Value="#FF7FBB4A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Выходной порт Success — изумрудный, центр по высоте карточки -->
                                    <Ellipse Grid.Column="2" Tag="Success"
                                             Width="12" Height="12"
                                             Fill="#FF22C55E" Stroke="#FF16A34A"
                                             StrokeThickness="1"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortSuccess}">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Fill"   Value="#FF4ADE80"/>
                                                        <Setter Property="Effect" Value="{StaticResource TriggerWireGlowEffect}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </DataTemplate>

                            <!-- ══ Карточка Logic_SequenceNode: вертикальная золотая линейка ══ -->
                            <DataTemplate x:Key="NodeCardSequencerTemplate" DataType="{x:Type models:VisualNode}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Порт In (top-aligned) -->
                                    <Ellipse Grid.Column="0" Tag="In"
                                             Width="12" Height="12"
                                             Fill="#FF3A3A3A" Stroke="#FF888888"
                                             StrokeThickness="1"
                                             VerticalAlignment="Top" Margin="0,11,0,0"
                                             HorizontalAlignment="Center"
                                             Cursor="Hand" ToolTip="{x:Static res:Strings.Blueprint_PortIn}">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Fill"   Value="#FF555555"/>
                                                        <Setter Property="Stroke" Value="#FFD4AF37"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Золотое свечение: Executing / Success -->
                                    <Border x:Name="SeqGoldGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="4"
                                            Background="#33D4AF37"
                                            BorderThickness="0"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="4" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Рубиновое свечение: Failed -->
                                    <Border x:Name="SeqRubyGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="4"
                                            Background="#33CC2222"
                                            BorderThickness="0"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFCC2222" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Тело карточки: вертикальная линейка -->
                                    <Border x:Name="SeqCardBorder"
                                            Grid.Column="1"
                                            Background="#FF1C1400"
                                            CornerRadius="4" Padding="4,6"
                                            MinHeight="80" Cursor="SizeAll"
                                            Tag="{Binding DataContext,
                                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                                        </Border.Effect>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{x:Static res:Strings.Blueprint_NodeCtxSetStart}"
                                                          Command="{Binding PlacementTarget.Tag.SetAsStartNodeCommand,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                                <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>
                                                <MenuItem Header="{x:Static res:Strings.Blueprint_NodeCtxDelete}"
                                                          Command="{Binding PlacementTarget.Tag.DeleteNodeCommand,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Foreground" Value="{StaticResource RubyBrush}"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFFF4444"/>
                                                                    <Setter Property="Effect"     Value="{StaticResource RubyGlowEffect}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush"     Value="#FFD4AF37"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FFF5D77F"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#FFD4AF37"
                                                       FontFamily="Consolas" FontSize="7" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ItemsControl ItemsSource="{Binding LogicalNode.Steps}" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,3">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="#FF999999"
                                                                       FontFamily="Consolas" FontSize="7"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       HorizontalAlignment="Center"/>
                                                            <StackPanel Orientation="Horizontal"
                                                                        HorizontalAlignment="Center"
                                                                        Margin="0,2,0,0">
                                                                <Ellipse Width="5" Height="5" Margin="1,0">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="#FF2A2A2A"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSuccessConnected}" Value="True">
                                                                                    <Setter Property="Fill" Value="#FFD4AF37"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <Ellipse Width="5" Height="5" Margin="1,0">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="#FF2A2A2A"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsDataConnected}" Value="True">
                                                                                    <Setter Property="Fill" Value="#FFAAAAAA"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <Ellipse Width="5" Height="5" Margin="1,0">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="#FF2A2A2A"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsErrorConnected}" Value="True">
                                                                                    <Setter Property="Fill" Value="#FF8B0000"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                            </StackPanel>
                                                            <Border Height="1" Background="#1AD4AF37" Margin="1,3,1,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Выходные порты (после всех шагов): Success / Data / Error -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="0,5,0,0">
                                        <Ellipse Tag="Success"
                                                 Width="12" Height="12"
                                                 Fill="#FFD4AF37" Stroke="#FFAA7C11"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,4"
                                                 Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortSuccess}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill"   Value="#FFF5D77F"/>
                                                            <Setter Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Ellipse Tag="Data"
                                                 Width="12" Height="12"
                                                 Fill="#FF2A2A2A" Stroke="{StaticResource SilverDataPortBrush}"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,4"
                                                 Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortData}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill"   Value="#FF444444"/>
                                                            <Setter Property="Stroke" Value="#FFE8E8E8"/>
                                                            <Setter Property="Effect" Value="{StaticResource SilverGlowEffect}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Ellipse Tag="Error"
                                                 Width="12" Height="12"
                                                 Fill="#FF8B0000" Stroke="#FF5A0000"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 Cursor="Cross" ToolTip="{x:Static res:Strings.Blueprint_PortError}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill"   Value="{StaticResource RubyBrush}"/>
                                                            <Setter Property="Stroke" Value="{StaticResource RubyBrush}"/>
                                                            <Setter Property="Effect" Value="{StaticResource RubyGlowEffect}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <!-- Hover: свечение -->
                                    <EventTrigger RoutedEvent="Border.MouseEnter" SourceName="SeqCardBorder">
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="26" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.85" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Border.MouseLeave" SourceName="SeqCardBorder">
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="16" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                 Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.4" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <!-- IsSelected: усиление свечения -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="30" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.95" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="16" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="SeqCardBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.4" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- Executing: золотое пульсирование -->
                                    <DataTrigger Binding="{Binding State}" Value="Executing">
                                        <Setter TargetName="SeqGoldGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SeqExecutingSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="SeqGoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="4" To="14" Duration="0:0:0.6"/>
                                                    <DoubleAnimation Storyboard.TargetName="SeqGoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.3" To="0.9" Duration="0:0:0.6"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SeqExecutingSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- Success: золото гаснет -->
                                    <DataTrigger Binding="{Binding State}" Value="Success">
                                        <Setter TargetName="SeqGoldGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SeqSuccessSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SeqGoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="14" To="4" Duration="0:0:1"/>
                                                    <DoubleAnimation Storyboard.TargetName="SeqGoldGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.9" To="0.0" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SeqSuccessSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- Failed: рубиновое пульсирование -->
                                    <DataTrigger Binding="{Binding State}" Value="Failed">
                                        <Setter TargetName="SeqRubyGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SeqFailedSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="SeqRubyGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="8" To="18" Duration="0:0:0.4"/>
                                                    <DoubleAnimation Storyboard.TargetName="SeqRubyGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.4" To="1.0" Duration="0:0:0.4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SeqFailedSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>

                            <!-- ══ Карточка Logic_QueueBlockNode: компактный золотой блок 100×60 ══ -->
                            <DataTemplate x:Key="NodeCardQueueBlockTemplate" DataType="{x:Type models:VisualNode}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Порт In (слева) — мятный: принимает очередные звенья цепочки -->
                                    <Ellipse Grid.Column="0" Tag="In"
                                             Width="12" Height="12"
                                             Fill="#FF10B981" Stroke="#FF0D9668"
                                             StrokeThickness="1"
                                             VerticalAlignment="Top" Margin="0,21,0,0"
                                             HorizontalAlignment="Center"
                                             Cursor="Hand" ToolTip="{x:Static res:Strings.Blueprint_PortIn}">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Fill"   Value="#FF34D399"/>
                                                        <Setter Property="Effect" Value="{StaticResource QueueWireGlowEffect}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Постоянное золотое свечение (Idle) -->
                                    <Border x:Name="QbIdleGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="6"
                                            Background="Transparent"
                                            BorderThickness="1"
                                            BorderBrush="#88D4AF37"
                                            MinHeight="60">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="6" ShadowDepth="0" Opacity="0.55"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Пульсирующее золотое свечение: Executing -->
                                    <Border x:Name="QbExecGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="6"
                                            Background="#22D4AF37"
                                            BorderThickness="0"
                                            MinHeight="60"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFD4AF37" BlurRadius="14" ShadowDepth="0" Opacity="0.9"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Рубиновое свечение: Failed -->
                                    <Border x:Name="QbRubyGlowBorder"
                                            Grid.Column="1"
                                            IsHitTestVisible="False"
                                            CornerRadius="6"
                                            Background="#33CC2222"
                                            BorderThickness="0"
                                            MinHeight="60"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FFCC2222" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Тело карточки -->
                                    <Border Grid.Column="1"
                                            CornerRadius="6"
                                            Background="#FF1E1E1E"
                                            BorderBrush="#55D4AF37"
                                            BorderThickness="1"
                                            MinHeight="60"
                                            Cursor="SizeAll"
                                            Tag="{Binding DataContext,
                                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                        <Border.ContextMenu>
                                            <ContextMenu Style="{StaticResource ObsidianContextMenuStyle}">
                                                <MenuItem Header="{x:Static res:Strings.Blueprint_NodeCtxSetStart}"
                                                          Command="{Binding PlacementTarget.Tag.SetAsStartNodeCommand,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                                <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>
                                                <MenuItem Header="{x:Static res:Strings.Blueprint_NodeCtxDelete}"
                                                          Command="{Binding PlacementTarget.Tag.DeleteNodeCommand,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Foreground" Value="{StaticResource RubyBrush}"/>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <!-- Иконка Q -->
                                            <TextBlock Text="Q"
                                                       Foreground="#FFD4AF37"
                                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                                       Margin="6,5,0,0"/>
                                            <!-- Имя ноды -->
                                            <TextBlock Text="{Binding LogicalNode.Name}"
                                                       Foreground="#FFF5D77F"
                                                       FontFamily="Consolas" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       Margin="4,0,4,0"/>
                                            <!-- Индикатор режима -->
                                            <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                       FontFamily="Consolas" FontSize="8"
                                                       Foreground="#88D4AF37" Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▶▶▶"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LogicalNode.WaitFullChain}" Value="False">
                                                                <Setter Property="Text" Value="▶ N"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Выход Success — мятный: передаёт управление следующему блоку очереди -->
                                    <Ellipse Grid.Column="2" Tag="Success"
                                             Width="12" Height="12"
                                             Fill="#FF10B981" Stroke="#FF0D9668"
                                             StrokeThickness="1"
                                             VerticalAlignment="Top" Margin="0,5,0,0"
                                             HorizontalAlignment="Center"
                                             Cursor="Hand" ToolTip="{x:Static res:Strings.Blueprint_PortSuccess}">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Fill"   Value="#FF34D399"/>
                                                        <Setter Property="Effect" Value="{StaticResource QueueWireGlowEffect}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Выход Error (красный) — Data-порт удалён намеренно -->
                                    <Ellipse Grid.Column="2" Tag="Error"
                                             Width="12" Height="12"
                                             Fill="#FF3A3A3A" Stroke="#FFCC2222"
                                             StrokeThickness="1"
                                             VerticalAlignment="Top" Margin="0,37,0,0"
                                             HorizontalAlignment="Center"
                                             Cursor="Hand" ToolTip="{x:Static res:Strings.Blueprint_PortError}"/>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <!-- Executing: золотое пульсирование -->
                                    <DataTrigger Binding="{Binding State}" Value="Executing">
                                        <Setter TargetName="QbExecGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="QbExecSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="QbExecGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="8" To="20" Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="QbExecGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.5" To="1.0" Duration="0:0:0.5"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="QbExecSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- Success: золотое затухание -->
                                    <DataTrigger Binding="{Binding State}" Value="Success">
                                        <Setter TargetName="QbExecGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="QbSuccessSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="QbExecGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="14" To="4" Duration="0:0:1"/>
                                                    <DoubleAnimation Storyboard.TargetName="QbExecGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.9" To="0.0" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="QbSuccessSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- Failed: рубиновое пульсирование -->
                                    <DataTrigger Binding="{Binding State}" Value="Failed">
                                        <Setter TargetName="QbRubyGlowBorder" Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="QbFailedSB" HandoffBehavior="SnapshotAndReplace">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="QbRubyGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                     From="8" To="18" Duration="0:0:0.4"/>
                                                    <DoubleAnimation Storyboard.TargetName="QbRubyGlowBorder"
                                                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.4" To="1.0" Duration="0:0:0.4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="QbFailedSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>

                            <converters:VisualNodeCardSelector x:Key="NodeCardSelector"
                                DefaultTemplate="{StaticResource NodeCardDefaultTemplate}"
                                SequencerTemplate="{StaticResource NodeCardSequencerTemplate}"
                                QueueBlockTemplate="{StaticResource NodeCardQueueBlockTemplate}"
                                TriggerRootTemplate="{StaticResource NodeCardTriggerRootTemplate}"/>
                        </ItemsControl.Resources>
                        <ItemsControl.ItemTemplateSelector>
                            <converters:VisualNodeCardSelector
                                DefaultTemplate="{StaticResource NodeCardDefaultTemplate}"
                                SequencerTemplate="{StaticResource NodeCardSequencerTemplate}"
                                QueueBlockTemplate="{StaticResource NodeCardQueueBlockTemplate}"
                                TriggerRootTemplate="{StaticResource NodeCardTriggerRootTemplate}"/>
                        </ItemsControl.ItemTemplateSelector>
                    </ItemsControl>

                    <!-- Предварительный просмотр связи -->
                    <Path x:Name="PreviewPath"
                          Stroke="#AAD4AF37" StrokeThickness="2"
                          StrokeDashArray="6,3"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Visibility="Collapsed" IsHitTestVisible="False"
                          Canvas.Left="0" Canvas.Top="0"/>
                </Canvas>
            </ScrollViewer>
            </AdornerDecorator>

            <!-- ── Кнопка-переключатель: Toolbox (левая граница холста) ──────
                 Checked = панель скрыта  →  шеврон ▶ (expand)
                 Unchecked = панель видна →  шеврон ◀ (collapse)              -->
            <ToggleButton x:Name="ToggleToolbox"
                          Style="{StaticResource PanelToggleStyle}"
                          HorizontalAlignment="Left"
                          ToolTip="{x:Static res:Strings.Blueprint_ToolboxToggle}">

                <!-- Шеврон меняет направление в зависимости от IsChecked -->
                <Path StrokeThickness="1.5"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Stroke="{StaticResource GoldBrush}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <!-- ◀  — панель открыта, нажать чтобы закрыть -->
                            <Setter Property="Data" Value="M9,4 L5,8 L9,12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked,
                                    RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                             Value="True">
                                    <!-- ▶ — панель закрыта, нажать чтобы открыть -->
                                    <Setter Property="Data" Value="M5,4 L9,8 L5,12"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>

                <!-- Анимации ширины Toolbox: Checked=collapse(0ms→250ms) / Unchecked=expand -->
                <ToggleButton.Triggers>
                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ToolboxBorder"
                                                 Storyboard.TargetProperty="Width"
                                                 To="0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ToolboxBorder"
                                                 Storyboard.TargetProperty="Width"
                                                 To="220" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ToggleButton.Triggers>
            </ToggleButton>

            <!-- ── Кнопка-переключатель: Properties (правая граница холста) ─
                 Checked = панель скрыта  →  шеврон ◀ (expand)
                 Unchecked = панель видна →  шеврон ▶ (collapse)             -->
            <ToggleButton x:Name="ToggleProps"
                          Style="{StaticResource PanelToggleStyle}"
                          HorizontalAlignment="Right"
                          ToolTip="{x:Static res:Strings.Blueprint_PropsToggle}">

                <Path StrokeThickness="1.5"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Stroke="{StaticResource GoldBrush}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <!-- ▶ — панель открыта, нажать чтобы закрыть -->
                            <Setter Property="Data" Value="M5,4 L9,8 L5,12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked,
                                    RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                             Value="True">
                                    <!-- ◀ — панель закрыта, нажать чтобы открыть -->
                                    <Setter Property="Data" Value="M9,4 L5,8 L9,12"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>

                <ToggleButton.Triggers>
                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="PropsBorder"
                                                 Storyboard.TargetProperty="Width"
                                                 To="0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="PropsBorder"
                                                 Storyboard.TargetProperty="Width"
                                                 To="280" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ToggleButton.Triggers>
            </ToggleButton>

            <!-- ════ GridSplitter: виден только когда консоль открыта ═══════ -->
            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                          Background="#FF1A1A1A" Cursor="SizeNS">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDebugConsoleOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- ════ Выдвижная консоль отладки (выезжает снизу) ════════════ -->
            <Border Grid.Row="2" Height="0" ClipToBounds="True"
                    Background="#F2121212" BorderBrush="#FF2A2A2A" BorderThickness="0,1,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDebugConsoleOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                             To="160" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок консоли -->
                    <Border Grid.Row="0" Background="#FF151515" Padding="10,5">
                        <Grid>
                            <TextBlock Text="ЖУРНАЛ ОТЛАДКИ ДЕЙСТВИЯ"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right"
                                    Command="{Binding CloseDebugConsoleCommand}"
                                    Width="22" Height="22" Padding="0"
                                    FontFamily="Consolas" FontSize="13">
                                <TextBlock Text="✕" VerticalAlignment="Center"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Лог отладки -->
                    <TextBox Grid.Row="1"
                             Text="{Binding NodeDebugLogs, Mode=OneWay}"
                             Tag="Ожидание теста..."
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="#F2121212"
                             Foreground="#FFA0A0A0"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Padding="10,6"
                             SelectionBrush="#FFF5D77F"
                             SelectionOpacity="0.3"/>
                </Grid>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             Колонка 2: Properties Panel  (схлопывается до Width=0)
        ═══════════════════════════════════════════════════════════════════════ -->
        <Border x:Name="PropsBorder"
                Grid.Column="2"
                Width="280"
                MinWidth="0"
                ClipToBounds="True"
                Background="#FF121212"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5,0,0,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,10,12,14">

                    <TextBlock Text="{x:Static res:Strings.Blueprint_PropsHeader}"
                               Foreground="{StaticResource GoldBrush}"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <!-- Пустое состояние -->
                    <TextBlock Text="{x:Static res:Strings.Blueprint_PropsEmpty}"
                               Foreground="#FF444444"
                               FontFamily="Segoe UI" FontSize="11"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Детали выделенной ноды -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Заголовок ноды + маркер опасности [!] -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedNode.LogicalNode.Name}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Width="16" Height="16" CornerRadius="8"
                                    Background="#FFFF3B30" Margin="6,0,0,0"
                                    VerticalAlignment="Center" Cursor="Help">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNode.LogicalNode.IsDangerous}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.ToolTip>
                                    <ToolTip Style="{StaticResource ObsidianToolTipStyle}"
                                             DataContext="{Binding PlacementTarget.DataContext,
                                                          RelativeSource={RelativeSource Self}}">
                                        <StackPanel>
                                            <TextBlock Text="ВНИМАНИЕ — ОПАСНОЕ ДЕЙСТВИЕ"
                                                       Foreground="#FFFF3B30" FontFamily="Segoe UI"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding SelectedNode.LogicalNode.DangerWarningText}"
                                                       Foreground="#FF9A9A6A" FontFamily="Segoe UI"
                                                       FontSize="10" TextWrapping="Wrap" MaxWidth="230"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="!" Foreground="White"
                                           FontFamily="Segoe UI" FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,-1,0,0"/>
                            </Border>
                        </Grid>

                        <Rectangle Height="1" Fill="#FF2A2A2A" Margin="0,0,0,12"/>

                        <ContentControl Content="{Binding SelectedNode.LogicalNode}"/>

                        <!-- Кнопки тестирования ноды и цепочки -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Тест одной ноды -->
                            <Button Grid.Column="0"
                                    Command="{Binding TestNodeCommand}"
                                    FontFamily="Consolas" FontSize="10" Padding="8,6">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Path Data="M4,2 L14,8 L4,14 Z" Fill="#FFD4AF37"
                                          Stretch="Uniform" Width="8" Height="8" Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Тест ноды" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Тест цепочки начиная с выбранной ноды -->
                            <Button Grid.Column="2"
                                    Command="{Binding TestChainCommand}"
                                    FontFamily="Consolas" FontSize="10" Padding="8,6">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Path Data="M2,2 L9,8 L2,14 M9,2 L16,8 L9,14"
                                          Stroke="#FFD4AF37" StrokeThickness="2"
                                          Stretch="Uniform" Width="10" Height="8" Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Тест цепочки" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
