<Window x:Class="ARK.UI.Views.PriorityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приоритет в очереди"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Inputs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="10">
        <Border Background="{StaticResource ObsidianBackgroundBrush}"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Effect="{StaticResource GoldGlowEffect}">

            <StackPanel Margin="16,12,16,16">

                <!-- ── Заголовок + закрыть ── -->
                <Grid Margin="0,0,0,12"
                      MouseLeftButtonDown="OnTitleBarDrag"
                      Cursor="SizeAll">
                    <TextBlock Text="Задать приоритет в очереди"
                               Foreground="{StaticResource GoldBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="24" Height="24" Padding="4"
                            FontSize="12" Content="✕"
                            Click="OnCloseClick"/>
                </Grid>

                <!-- ── Пояснение ── -->
                <TextBlock Foreground="#FF888888" FontSize="10"
                           TextWrapping="Wrap" Margin="0,0,0,10">
                    <Run Text="Приоритет выполнения в очереди (1–99)."/>
                    <LineBreak/>
                    <Run Text="1 — наивысший, выполняется первым. 0 — приоритет не задан."/>
                </TextBlock>

                <!-- ── Поле ввода ── -->
                <TextBox x:Name="PriorityBox"
                         Foreground="#FFF5D77F"
                         Margin="0,0,0,14"
                         MaxLength="2"
                         PreviewTextInput="OnPreviewTextInput"
                         KeyDown="OnKeyDown"/>

                <!-- ── Кнопки ── -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Width="80" Margin="0,0,8,0"
                            Click="OnCloseClick"/>
                    <Button Content="OK" Width="80"
                            Click="OnOkClick"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Border>
</Window>
