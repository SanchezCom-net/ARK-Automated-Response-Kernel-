<UserControl x:Class="ARK.UI.Views.ObsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             xmlns:svc="clr-namespace:ARK.UI.Core.Services"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <svc:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <svc:PasswordEyeIconConverter         x:Key="PasswordEyeIcon"/>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#FF888888"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontFamily"  Value="Consolas"/>
                <Setter Property="Margin"      Value="0,0,0,4"/>
            </Style>

            <!-- Стиль кнопки Obsidian Gold (малая) -->
            <Style x:Key="ObsActionButton" TargetType="Button">
                <Setter Property="Background"      Value="#FF1A1A1A"/>
                <Setter Property="Foreground"      Value="{StaticResource GoldBrush}"/>
                <Setter Property="BorderBrush"     Value="#FF3A3A3A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14,7"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                    <Setter TargetName="Bd" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF2A1800"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- PasswordBox в стиле Obsidian Gold — визуально идентичен TextBox из Inputs.xaml -->
            <Style x:Key="ObsidianPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
                <Setter Property="Background"               Value="#FF121212"/>
                <Setter Property="Foreground"               Value="#FFF5D77F"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Padding"                  Value="6,4,30,4"/>
                <Setter Property="CaretBrush"               Value="{StaticResource GoldBrush}"/>
                <Setter Property="SelectionBrush"           Value="{StaticResource GoldBrush}"/>
                <Setter Property="SelectionOpacity"         Value="0.3"/>
                <Setter Property="FontSize"                 Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="PasswordChar"             Value="●"/>
                <Setter Property="SnapsToDevicePixels"      Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type PasswordBox}">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FF2A2A2A"/>
                                </Border.BorderBrush>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              OverridesDefaultStyle="True"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="MainBorder" Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <EventTrigger RoutedEvent="GotKeyboardFocus">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="MainBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FFD4AF37" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="LostKeyboardFocus">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="MainBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FF2A2A2A" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Кнопка-иконка без рамки (для глазика видимости пароля) -->
            <Style x:Key="ObsidianIconButtonStyle" TargetType="Button">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#22D4AF37"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#44D4AF37"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  FocusVisualStyle="{x:Null}">
        <StackPanel Margin="24,20,24,20">

            <!-- ══ Заголовок ══════════════════════════════════════════════════ -->
            <TextBlock Text="{x:Static res:Strings.Obs_Title}"
                       Foreground="{StaticResource GoldBrush}"
                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <Rectangle Height="1" Fill="{StaticResource GoldBrush}" Opacity="0.3"
                       Margin="0,0,0,16"/>

            <!-- ══ Индикатор статуса ══════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF6B2222"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsObsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#FF4CAF50"/>
                                    <Setter Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ObsStatusText}"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF6B2222"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsObsConnected}" Value="True">
                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- ══ Поля подключения: IP + Порт ══════════════════════════════ -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Static res:Strings.Obs_IpLabel}"
                               Style="{StaticResource FieldLabel}"/>
                    <!-- Tag используется как плейсхолдер темой Inputs.xaml (без ws://) -->
                    <TextBox Text="{Binding ObsIpAddress, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"
                             Tag="127.0.0.1"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{x:Static res:Strings.Obs_PortLabel}"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ObsPort, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#FFF5D77F"
                             Tag="4455"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{x:Static res:Strings.Obs_PasswordLabel}"
                       Style="{StaticResource FieldLabel}"/>
            <!-- Reveal PasswordBox: PasswordBox (маска) и TextBox (открытый) накладываются в Grid.
                 Переключаются через IsPasswordVisible. PasswordBehavior синхронизирует
                 PasswordBox.Password ↔ ObsPassword без code-behind. -->
            <Grid Margin="0,0,0,14">
                <!-- Слой 1: Маскированный ввод — PasswordBox с attached behavior -->
                <PasswordBox svc:PasswordBehavior.BoundPassword="{Binding ObsPassword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ObsidianPasswordBoxStyle}"
                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVis}}"
                             MaxLength="32"/>

                <!-- Слой 2: Открытый ввод — TextBox с прямым биндингом -->
                <TextBox Text="{Binding ObsPassword, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#FFF5D77F"
                         Padding="6,4,30,4"
                         Tag="Пароль OBS WebSocket (если установлен)"
                         Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVis}}"
                         MaxLength="32"/>

                <!-- Кнопка-переключатель видимости пароля (глазик) -->
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="24" Height="24"
                        Margin="0,0,4,0"
                        Command="{Binding TogglePasswordVisibilityCommand}"
                        Style="{StaticResource ObsidianIconButtonStyle}"
                        Focusable="False">
                    <Path Data="{Binding IsPasswordVisible, Converter={StaticResource PasswordEyeIcon}}"
                          Fill="#FFD4AF37"
                          Stretch="Uniform"
                          Width="14" Height="14"/>
                </Button>
            </Grid>

            <!-- ══ Автоподключение и авто-реконнект ════════════════════════════ -->
            <CheckBox Content="{x:Static res:Strings.Obs_AutoConnect}"
                      IsChecked="{Binding ObsAutoConnect}"
                      Foreground="#FFE0E0E0" Margin="0,0,0,8"/>
            <CheckBox Content="{x:Static res:Strings.Obs_AutoReconnect}"
                      IsChecked="{Binding ObsAutoReconnect}"
                      Foreground="#FFE0E0E0" Margin="0,0,0,8"/>
            <TextBlock Text="{x:Static res:Strings.Obs_ProtocolVersion}"
                       Style="{StaticResource FieldLabel}"
                       Margin="0,0,0,16"/>

            <!-- ══ Кнопки действий ═══════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="{x:Static res:Strings.Obs_ConnectBtn}"
                        Command="{Binding ConnectObsCommand}"
                        Style="{StaticResource ObsActionButton}"/>
                <Button Content="{x:Static res:Strings.Obs_DisconnectBtn}"
                        Command="{Binding DisconnectObsCommand}"
                        Style="{StaticResource ObsActionButton}"
                        Margin="8,0,0,0"/>
            </StackPanel>

            <Button Content="{x:Static res:Strings.Obs_SaveBtn}"
                    Command="{Binding SaveObsSettingsCommand}"
                    Style="{StaticResource ObsActionButton}"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
