<Window x:Class="ARK.UI.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARK"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Стиль PasswordBox в теме Obsidian Gold -->
            <Style TargetType="PasswordBox">
                <Setter Property="Background"      Value="#FF1A1A1A"/>
                <Setter Property="Foreground"      Value="#FFF5D77F"/>
                <Setter Property="BorderBrush"     Value="#FF3A3A3A"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding"         Value="5,4"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="CaretBrush"      Value="#FFD4AF37"/>
                <Setter Property="SelectionBrush"  Value="#55D4AF37"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FFD4AF37"/>
                                    <Setter TargetName="Bd" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF886A1E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Внешний отступ даёт место для GoldGlowEffect -->
    <Border Margin="10">
        <Border Background="{StaticResource ObsidianBackgroundBrush}"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Effect="{StaticResource GoldGlowEffect}">

            <StackPanel Margin="16,12,16,16">

                <!-- ── Заголовок + кнопка закрыть ── -->
                <Grid Margin="0,0,0,10"
                      MouseLeftButtonDown="OnTitleBarDrag"
                      Cursor="SizeAll">
                    <TextBlock x:Name="TitleText"
                               Foreground="{StaticResource GoldBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="24" Height="24"
                            Padding="4"
                            FontSize="12"
                            Content="✕"
                            Click="OnCloseClick"/>
                </Grid>

                <!-- ── Описание (опционально) ── -->
                <TextBlock x:Name="DescText"
                           Foreground="#FF888888"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <!-- ── Поле ввода пароля ── -->
                <PasswordBox x:Name="PassBox"
                             Margin="0,0,0,14"
                             KeyDown="OnKeyDown"/>

                <!-- ── Кнопки ── -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="OK"
                            Width="80"
                            Margin="0,0,8,0"
                            Click="OnOkClick"/>
                    <Button Content="Отмена"
                            Width="80"
                            Click="OnCloseClick"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Border>
</Window>
