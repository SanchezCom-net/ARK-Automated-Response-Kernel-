<UserControl x:Class="ARK.UI.Views.AiSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             xmlns:viewmodels="clr-namespace:ARK.UI.ViewModels"
             xmlns:models="clr-namespace:ARK.UI.Core.Models"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Inputs.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Метка поля -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#FF888888"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontFamily"  Value="Consolas"/>
                <Setter Property="Margin"      Value="0,0,0,4"/>
            </Style>

            <!-- RadioButton — Obsidian Gold -->
            <Style TargetType="{x:Type RadioButton}">
                <Setter Property="Foreground"        Value="#FFE0E0E0"/>
                <Setter Property="FontSize"          Value="13"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor"            Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RadioButton}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="RadioBorder"
                                        Width="16" Height="16"
                                        CornerRadius="8"
                                        Background="#FF0D0D0D"
                                        BorderBrush="#FF3A3A3A"
                                        BorderThickness="1.5"
                                        VerticalAlignment="Center"
                                        SnapsToDevicePixels="True">
                                    <Ellipse x:Name="Dot"
                                             Width="8" Height="8"
                                             Fill="{StaticResource GoldBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Margin="7,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Dot"         Property="Visibility"   Value="Visible"/>
                                    <Setter TargetName="RadioBorder" Property="BorderBrush"  Value="{StaticResource GoldBrush}"/>
                                    <Setter TargetName="RadioBorder" Property="Background"   Value="#FF100D00"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                    <Setter TargetName="RadioBorder" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Slider — Obsidian Gold: тёмный трек, золотой thumb -->
            <Style TargetType="{x:Type Slider}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Slider}">
                            <Grid SnapsToDevicePixels="True">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton OverridesDefaultStyle="True"
                                                      IsTabStop="False"
                                                      Command="{x:Static Slider.DecreaseLarge}">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="4"
                                                            VerticalAlignment="Center"
                                                            Background="{StaticResource GoldBrush}"
                                                            CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb OverridesDefaultStyle="True">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse x:Name="ThumbEllipse"
                                                             Width="14" Height="14"
                                                             Fill="{StaticResource GoldBrush}"
                                                             Effect="{StaticResource GoldGlowEffect}"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbEllipse" Property="Width"  Value="16"/>
                                                            <Setter TargetName="ThumbEllipse" Property="Height" Value="16"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton OverridesDefaultStyle="True"
                                                      IsTabStop="False"
                                                      Command="{x:Static Slider.IncreaseLarge}">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="4"
                                                            VerticalAlignment="Center"
                                                            Background="#FF2A2A2A"
                                                            CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ProgressBar VU-Meter: Obsidian подложка + золотое неоновое заполнение.
                 При IsMicrophonePeaking=True (>0.8) переключается в рубиновый.
                 PART_Track и PART_Indicator — обязательные имена для WPF ProgressBar. -->
            <Style x:Key="ObsidianProgressBarStyle" TargetType="{x:Type ProgressBar}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ProgressBar}">
                            <Grid SnapsToDevicePixels="True">
                                <!-- Подложка VU-Meter -->
                                <Border x:Name="PART_Track"
                                        Background="#FF0A0A0A"
                                        CornerRadius="4"
                                        BorderBrush="#33D4AF37"
                                        BorderThickness="1"/>
                                <!-- Заполнение: width устанавливается ProgressBar пропорционально Value -->
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="{StaticResource GoldBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FFD4AF37"
                                                          BlurRadius="8"
                                                          ShadowDepth="0"
                                                          Opacity="0.85"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <!-- Пиковый уровень: золото → рубин -->
                                <DataTrigger Binding="{Binding IsMicrophonePeaking}" Value="True">
                                    <Setter TargetName="PART_Indicator" Property="Background"
                                            Value="{StaticResource RubyBrush}"/>
                                    <Setter TargetName="PART_Indicator" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#FFB71C1C"
                                                              BlurRadius="10"
                                                              ShadowDepth="0"
                                                              Opacity="0.9"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Заголовок секции: ToggleButton с анимированным золотым шевроном -->
            <Style x:Key="SectionToggleStyle" TargetType="ToggleButton">
                <Setter Property="Focusable"           Value="False"/>
                <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
                <Setter Property="Cursor"              Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border BorderBrush="{StaticResource GoldBrush}"
                                    BorderThickness="0,1,0,0"
                                    Background="Transparent"
                                    Padding="12,8,12,8"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontFamily="Segoe UI"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <Path x:Name="Chevron"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M0,3 L5,7 L10,3"
                                          Stroke="{StaticResource GoldBrush}"
                                          StrokeThickness="1.5"
                                          Fill="Transparent"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="180"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- IsChecked=True → раскрыто: шеврон ↑ (180°) -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="Chevron"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    To="180" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="Chevron"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    To="0" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF0F0900"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!-- OpacityMask: отсекает острые углы ScrollViewer по радиусу скругления главного окна.
             CornerRadius="9" — чуть меньше внешнего "10" для сглаживания пограничных пикселей. -->
        <Grid.OpacityMask>
            <VisualBrush Stretch="None">
                <VisualBrush.Visual>
                    <Border Background="Black"
                            Width="{Binding ActualWidth, ElementName=RootGrid}"
                            Height="{Binding ActualHeight, ElementName=RootGrid}"
                            CornerRadius="9"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.OpacityMask>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Прокручиваемое тело с тремя секциями ══════════════════════════════ -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent"
                      Margin="0,6,6,6">
            <StackPanel>

                <!-- ────── Секция 1: ГОЛОСОВОЙ ВВОД ──────────────────────────── -->
                <ToggleButton x:Name="SpeechToggle"
                              Style="{StaticResource SectionToggleStyle}"
                              Content="{x:Static res:Strings.AiSettings_SpeechSection}"
                              IsChecked="True"/>

                <StackPanel Margin="12,8,12,12"
                            Visibility="{Binding IsChecked, ElementName=SpeechToggle, Converter={StaticResource BoolToVis}}">

                    <!-- Устройство захвата -->
                    <TextBlock Text="{x:Static res:Strings.AiSettings_Microphone}"
                               Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Microphones}"
                                  SelectedItem="{Binding SelectedMicrophone}"
                                  Margin="0,0,6,0"/>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshMicrophonesCommand}"
                                Padding="8,4"
                                ToolTip="{x:Static res:Strings.AiSettings_RefreshMics}">
                            <TextBlock Text="{x:Static res:Strings.AiSettings_RefreshMics}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Движок распознавания: Auto / Whisper / Vosk -->
                    <TextBlock Text="{x:Static res:Strings.AiSettings_Engine}"
                               Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{x:Static viewmodels:SettingsViewModel.AllSpeechEngines}"
                              SelectedItem="{Binding SelectedSpeechEngine}"
                              Margin="0,0,0,12"/>

                    <!-- Язык распознавания: ru / en -->
                    <TextBlock Text="{x:Static res:Strings.AiSettings_Language}"
                               Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{x:Static viewmodels:SettingsViewModel.SpeechLanguages}"
                              SelectedItem="{Binding SelectedSpeechLanguage}"
                              Margin="0,0,0,12"/>

                    <!-- Выбор модели Whisper — скрывается для Vosk -->
                    <StackPanel Margin="0,0,0,12">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWhisperSelected}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static res:Strings.AiSettings_WhisperModel}"
                                   Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{x:Static res:Strings.AiSettings_ModelBase}"
                                         IsChecked="{Binding IsBaseModelSelected}"
                                         Margin="0,0,20,0"/>
                            <RadioButton Content="{x:Static res:Strings.AiSettings_ModelTurbo}"
                                         IsChecked="{Binding IsTurboModelSelected}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Чувствительность VAD + VU-Meter -->
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Strings.AiSettings_Sensitivity}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding VadThreshold, StringFormat='{}{0:F2}'}"
                                   Foreground="{StaticResource GoldBrush}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- VU-Meter: уровень сигнала микрофона в реальном времени.
                         Выровнен по ширине со Slider ниже — пользователь видит соотношение
                         уровня звука и порога срабатывания VAD. -->
                    <ProgressBar Minimum="0" Maximum="1"
                                 Value="{Binding MicrophoneLevel, Mode=OneWay}"
                                 Style="{StaticResource ObsidianProgressBarStyle}"
                                 Height="8"
                                 Margin="0,0,0,4"/>

                    <!-- Slider порога VAD — визуально под VU-Meter для сопоставления уровней -->
                    <Slider Minimum="0.00"
                            Maximum="0.10"
                            Value="{Binding VadThreshold}"
                            TickFrequency="0.01"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,14"/>

                    <!-- Включить голосовой ввод -->
                    <CheckBox Content="{x:Static res:Strings.AiSettings_SpeechEnabled}"
                              IsChecked="{Binding IsSpeechEnabled}"
                              Margin="0,0,0,8"/>

                    <!-- Гейткипер имени активации -->
                    <CheckBox IsChecked="{Binding UseWakeWordGatekeeper, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="Требовать имя активации (гейткипер)"
                              Style="{StaticResource ObsidianCheckBoxStyle}"
                              Margin="0,0,0,8"
                              ToolTip="Включает защиту от ложных срабатываний. Макросы выполняются только при обращении по имени (например, «Виктория»). Если выключено — выполнение макросов голосом полностью блокируется (режим ожидания ИИ-ассистента)."/>

                    <!-- Имена активации (wake-word гейткипер) -->
                    <TextBlock Text="{x:Static res:Strings.AiSettings_ActivationNames}"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ActivationNames, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="{x:Static res:Strings.AiSettings_ActivationNamesHint}"
                               FontStyle="Italic"
                               FontSize="9"
                               Foreground="#FF888888"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <!-- Статус модели -->
                    <TextBlock Text="{x:Static res:Strings.AiSettings_ModelStatus}"
                               Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FFD32F2F"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModelLoaded}" Value="True">
                                            <Setter Property="Fill" Value="#FF7FBB4A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ModelStatusText}"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModelLoaded}" Value="True">
                                            <Setter Property="Foreground" Value="#FF7FBB4A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                </StackPanel>

                <!-- ────── Секция 2: ИНТЕЛЛЕКТ ИИ ─────────────────────────────── -->
                <ToggleButton x:Name="LlmToggle"
                              Style="{StaticResource SectionToggleStyle}"
                              Content="{x:Static res:Strings.AiSettings_LlmSection}"
                              IsChecked="True"/>

                <StackPanel Margin="12,8,12,12"
                            Visibility="{Binding IsChecked, ElementName=LlmToggle, Converter={StaticResource BoolToVis}}">

                    <!-- Включить ИИ-ассистента (всегда активен) -->
                    <CheckBox Content="{x:Static res:Strings.AiSettings_AiEnabled}"
                              IsChecked="{Binding IsAiEnabled}"
                              Margin="0,0,0,12"/>

                    <!-- Основной контент секции: блокируется при IsAiEnabled=False -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAiEnabled}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Адрес API Ollama -->
                        <TextBlock Text="{x:Static res:Strings.AiSettings_OllamaUrl}"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding OllamaApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,12"/>

                        <!-- Языковая модель -->
                        <TextBlock Text="{x:Static res:Strings.AiSettings_OllamaModel}"
                                   Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding OllamaModels}"
                                      SelectedItem="{Binding SelectedOllamaModel}"
                                      IsEnabled="{Binding IsOllamaAvailable}"
                                      Margin="0,0,6,0"/>
                            <Button Grid.Column="1"
                                    Command="{Binding RefreshOllamaModelsCommand}"
                                    Padding="8,4"
                                    ToolTip="{x:Static res:Strings.AiSettings_RefreshModels}">
                                <TextBlock Text="{x:Static res:Strings.AiSettings_RefreshModels}"
                                           Foreground="{StaticResource GoldBrush}"
                                           FontSize="14"/>
                            </Button>
                        </Grid>

                        <!-- Имена активации ИИ-ассистента -->
                        <TextBlock Text="Имена активации ИИ-ассистента (через запятую)"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding AiAssistantNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Аркаша, Аркадий..."
                                 Margin="0,0,0,4"
                                 ToolTip="Укажите имена, на которые будет отзываться локальный ИИ-ассистент (например, Аркаша, Аркадий). Имена не должны совпадать с именами голосовых макросов."/>
                        <TextBlock Text="Не должны совпадать с именами активации макросов"
                                   FontStyle="Italic"
                                   FontSize="9"
                                   Foreground="#FF888888"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <!-- Кнопка настройки характера ассистента (Gold) -->
                        <Button HorizontalAlignment="Stretch"
                                Command="{Binding OpenAiCharacterCommand}">
                            <TextBlock Text="{x:Static res:Strings.AiSettings_CharacterBtn}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </Button>

                    </StackPanel>

                </StackPanel>

                <!-- ────── Секция 3: СИНТЕЗАТОР РЕЧИ ──────────────────────── -->
                <ToggleButton x:Name="TtsToggle"
                              Style="{StaticResource SectionToggleStyle}"
                              Content="{x:Static res:Strings.AiSettings_TtsSection}"
                              IsChecked="True"/>

                <StackPanel Margin="12,8,12,12"
                            Visibility="{Binding IsChecked, ElementName=TtsToggle, Converter={StaticResource BoolToVis}}">

                    <!-- Субтитры оверлея -->
                    <CheckBox Content="{x:Static res:Strings.AiSettings_ShowSubtitles}"
                              IsChecked="{Binding ShowAiSubtitles}"
                              Margin="0,0,0,12"/>

                    <!-- Режим синтеза -->
                    <TextBlock Text="{x:Static res:Strings.AiSettings_TtsMode}"
                               Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{x:Static viewmodels:SettingsViewModel.AllTtsModes}"
                              SelectedItem="{Binding SelectedTtsMode}"
                              Margin="0,0,0,12"/>

                    <!-- Всё ниже блокируется при Disabled -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTtsMode}"
                                                 Value="{x:Static models:TtsMode.Disabled}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Голос + кнопка Прослушать -->
                        <TextBlock Text="{x:Static res:Strings.AiSettings_TtsVoice}"
                                   Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedTtsVoice}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ClipToBounds="True">
                                            <TextBlock Text="{Binding}"
                                                       Style="{StaticResource MarqueeTextBlockStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Кнопка Прослушать / Стоп -->
                            <Button Grid.Column="2"
                                    Command="{Binding PlayVoicePreviewCommand}"
                                    Width="34" Height="34"
                                    IsEnabled="{Binding IsTtsActive}"
                                    ToolTip="{x:Static res:Strings.AiSettings_TtsPreview}"
                                    OverridesDefaultStyle="True"
                                    SnapsToDevicePixels="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Width="34" Height="34"
                                                CornerRadius="17"
                                                BorderThickness="1.5"
                                                BorderBrush="{StaticResource GoldBrush}"
                                                Background="#FF0D0D0D"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#FF100D00"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsPreviewPlaying}" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                        Value="{StaticResource RubyBrush}"/>
                                                <Setter TargetName="Bd" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#FFB71C1C"
                                                                          BlurRadius="12"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.9"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <!-- Иконка: Play (золото) / Stop (рубин) -->
                                <Grid Width="14" Height="14">
                                    <Path Data="M8,5 L19,12 L8,19 Z"
                                          Stretch="Uniform"
                                          Fill="{StaticResource GoldBrush}">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPreviewPlaying}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <Path Data="M6,6 L18,6 L18,18 L6,18 Z"
                                          Stretch="Uniform"
                                          Fill="{StaticResource RubyBrush}">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPreviewPlaying}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </Button>
                        </Grid>

                        <!-- Скорость речи -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static res:Strings.AiSettings_TtsSpeed}"
                                       Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TtsSpeed, StringFormat='{}{0:F1}×'}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider Minimum="0.5" Maximum="1.5"
                                Value="{Binding TtsSpeed}"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,14"/>

                        <!-- Громкость -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static res:Strings.AiSettings_TtsVolume}"
                                       Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TtsVolume, StringFormat='{}{0:P0}'}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider Minimum="0.0" Maximum="1.0"
                                Value="{Binding TtsVolume}"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,4"/>

                    </StackPanel>

                </StackPanel>

                <!-- ────── Секция 4: СЕТЕВОЙ КЛИЕНТ ──────────────────────────── -->
                <ToggleButton x:Name="NetToggle"
                              Style="{StaticResource SectionToggleStyle}"
                              Content="{x:Static res:Strings.AiSettings_NetworkSection}"
                              IsChecked="True"/>

                <StackPanel Margin="12,8,12,12"
                            Visibility="{Binding IsChecked, ElementName=NetToggle, Converter={StaticResource BoolToVis}}">

                    <!-- WebSocket URL -->
                    <TextBlock Text="{x:Static res:Strings.Net_ServerUrl}"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding WebSocketUrl, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12"/>

                    <!-- Статус подключения -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FFD32F2F"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNetworkConnected}" Value="True">
                                            <Setter Property="Fill" Value="#FF7FBB4A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding NetworkStatusText}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNetworkConnected}" Value="True">
                                            <Setter Property="Foreground" Value="#FF7FBB4A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Переподключение -->
                    <Button HorizontalAlignment="Left"
                            Command="{Binding ReconnectNetworkCommand}">
                        <TextBlock Text="{x:Static res:Strings.Net_Reconnect}"/>
                    </Button>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ Панель кнопок — прикреплена к низу ══════════════════════════════ -->
        <Border Grid.Row="1"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Сбросить сессию ИИ (Ruby) -->
                <Button Grid.Column="0"
                        Command="{Binding ResetSessionCommand}">
                    <TextBlock Text="{x:Static res:Strings.AiSettings_ResetSession}"
                               Foreground="{StaticResource RubyBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </Button>

                <!-- Применить настройки (Gold) -->
                <Button Grid.Column="2"
                        Command="{Binding SaveSettingsCommand}">
                    <TextBlock Text="{x:Static res:Strings.AiSettings_SaveSettings}"
                               Foreground="{StaticResource GoldBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>
    </Grid>

</UserControl>
