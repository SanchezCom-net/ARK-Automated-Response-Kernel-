<UserControl x:Class="ARK.UI.Views.MacroExplorerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ARK.UI.ViewModels"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BtV"/>

        <!--
            BreadcrumbButtonStyle: OverridesDefaultStyle=True гарантирует, что кнопки хлебных крошек
            НЕ наследуют глобальный Button-стиль из Buttons.xaml.
            Глобальный стиль содержит Storyboard-анимации с TargetName="MainBorder"; когда они
            запускаются из DataTemplate внутри DataTemplate, WPF не может разрешить имя в
            скоупе ControlTemplate и бросает InvalidOperationException.
        -->
        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="Padding"               Value="3,1"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Компактная кнопка для действий в панели настроек профиля -->
        <Style x:Key="ProfileActionButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="#FF252525"/>
            <Setter Property="Foreground"            Value="#FFCCAA44"/>
            <Setter Property="BorderBrush"           Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="7,3"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FontSize"              Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E2500"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFCCAA44"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1A1800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль CheckBox в панели настроек профиля — наследует глобальный ControlTemplate -->
        <Style x:Key="ProfileCheckBoxStyle" TargetType="CheckBox"
               BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="#FFCCAA44"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- Стиль TextBox в панели настроек профиля — наследует глобальный ControlTemplate -->
        <Style x:Key="ProfileTextBoxStyle" TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background"     Value="#FF1A1A1A"/>
            <Setter Property="Foreground"     Value="#FFCCAA44"/>
            <Setter Property="Padding"        Value="5,3"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="CaretBrush"     Value="#FFCCAA44"/>
            <Setter Property="SelectionBrush" Value="#66CCAA44"/>
        </Style>

        <!-- Стиль ComboBox в панели настроек профиля — наследует глобальный ControlTemplate -->
        <Style x:Key="ProfileComboBoxStyle" TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="#FF1A1A1A"/>
            <Setter Property="Foreground" Value="#FFCCAA44"/>
            <Setter Property="Padding"    Value="5,3"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Навигация -->
            <RowDefinition Height="Auto"/>  <!-- 1: Тулбар -->
            <RowDefinition Height="Auto"/>  <!-- 2: Настройки профиля -->
            <RowDefinition Height="*"/>     <!-- 3: Контент -->
        </Grid.RowDefinitions>

        <!-- ══ Строка навигации ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel>
                <!-- Кнопка назад -->
                <Button DockPanel.Dock="Left"
                        Command="{Binding NavigateBackCommand}"
                        Padding="8,4"
                        Margin="0,0,10,0">
                    <TextBlock Text="{x:Static res:Strings.Explorer_Back}" FontSize="12"/>
                </Button>

                <!-- Breadcrumbs -->
                <ItemsControl DockPanel.Dock="Left"
                              ItemsSource="{Binding Breadcrumbs}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:BreadcrumbItem}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource BreadcrumbButtonStyle}"
                                        Command="{Binding NavigateToCmd}">
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontSize="12"/>
                                </Button>
                                <TextBlock Text=" ›"
                                           Foreground="#FF555555"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ══ Панель инструментов ═══════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Orientation="Horizontal">

                <!-- Создать программу (только на корневом уровне) -->
                <Button Command="{Binding CreateProfileCommand}"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Explorer_CreateProfile}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Создать обычную папку (только внутри программы или папки) -->
                <Button Command="{Binding CreateFolderCommand}"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Explorer_CreateFolder}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Создать макрос (только внутри программы или папки) -->
                <Button Command="{Binding CreateMacroCommand}"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Explorer_CreateMacro}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Разделитель -->
                <Separator Width="1" Height="16"
                           Background="#FF3A3A3A"
                           VerticalAlignment="Center"
                           Margin="3,0,9,0"/>

                <!-- Экспорт профиля (активна при выборе профиля) -->
                <Button Command="{Binding ExportProfileCommand}"
                        ToolTip="Экспорт профиля в зашифрованный пакет .ark"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12"
                              Stretch="Uniform"
                              Data="M6,9 L6,1 M3,4 L6,1 9,4 M1,11 L11,11"
                              Stroke="{StaticResource GoldBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Margin="0,0,5,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Profile_Export}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Импорт профиля (всегда активна) -->
                <Button Command="{Binding ImportProfileCommand}"
                        ToolTip="Импорт профиля из пакета .ark"
                        Padding="9,4">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12"
                              Stretch="Uniform"
                              Data="M6,2 L6,10 M3,7 L6,10 9,7 M1,1 L11,1"
                              Stroke="{StaticResource GoldBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Margin="0,0,5,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Profile_Import}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══ Панель настроек профиля (Row 2, видна только на уровне InProfile) ═══ -->
        <Border Grid.Row="2"
                Visibility="{Binding IsProfileSettingsVisible, Converter={StaticResource BtV}}"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Background="#FF111111"
                Padding="12,10,12,12">
            <StackPanel>

                <!-- Заголовок секции -->
                <TextBlock Text="{x:Static res:Strings.Profile_SectionTitle}"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="#FF666666"
                           Margin="0,0,0,9"/>

                <!-- Флаг IsGlobal -->
                <CheckBox Style="{StaticResource ProfileCheckBoxStyle}"
                          Content="{x:Static res:Strings.Profile_IsGlobal}"
                          IsChecked="{Binding ProfileIsGlobal}"/>

                <!-- Секция привязки к процессу — скрывается при IsGlobal=True -->
                <StackPanel Margin="0,4,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProfileIsGlobal}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Процесс: ComboBox + кнопка Обновить -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Strings.Profile_TargetProcess}"
                                   Foreground="#FF888888"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource ProfileComboBoxStyle}"
                                  IsEditable="True"
                                  ItemsSource="{Binding ProcessSuggestions}"
                                  SelectedItem="{Binding SelectedProcess}"
                                  Text="{Binding ProfileTargetProcess, UpdateSourceTrigger=PropertyChanged}"
                                  TextSearch.TextPath="ProcessName"
                                  Margin="0,0,5,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ProcessInfo}">
                                    <StackPanel Orientation="Horizontal" Height="20">
                                        <Image Source="{Binding Icon}"
                                               Width="16" Height="16"
                                               Margin="0,0,5,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Text="{Binding ProcessName}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="#FFCCAA44"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="2"
                                Style="{StaticResource ProfileActionButtonStyle}"
                                Command="{Binding LoadProcessesCommand}"
                                Content="{x:Static res:Strings.Profile_RefreshProcesses}"
                                ToolTip="Обновить список запущенных процессов"/>
                    </Grid>

                    <!-- FocusRequired -->
                    <CheckBox Style="{StaticResource ProfileCheckBoxStyle}"
                              Content="{x:Static res:Strings.Profile_FocusRequired}"
                              IsChecked="{Binding ProfileFocusRequired}"/>

                    <!-- Фильтр заголовка окна -->
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Strings.Profile_WindowTitleFilter}"
                                   Foreground="#FF888888"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ProfileTextBoxStyle}"
                                 Text="{Binding ProfileWindowTitleFilter, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Фильтр по части заголовка окна (регистр не важен)"/>
                    </Grid>

                </StackPanel>

                <!-- Кнопка применить изменения -->
                <Button Style="{StaticResource ProfileActionButtonStyle}"
                        Command="{Binding SaveProfileCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0"
                        Padding="12,5"
                        FontSize="11"
                        Content="{x:Static res:Strings.Profile_SaveChanges}"/>

            </StackPanel>
        </Border>

        <!-- ══ Контентная область ════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="3"
                      Background="Transparent"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- Контекстное меню пустого пространства холста (не карточки) -->
            <ScrollViewer.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateProfile}"
                              Command="{Binding PlacementTarget.DataContext.CreateProfileCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                    <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateFolder}"
                              Command="{Binding PlacementTarget.DataContext.CreateFolderCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                    <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateMacro}"
                              Command="{Binding PlacementTarget.DataContext.CreateMacroCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                    <Separator/>
                    <MenuItem Header="{x:Static res:Strings.Explorer_Paste}"
                              Command="{Binding PlacementTarget.DataContext.PasteMacroCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                </ContextMenu>
            </ScrollViewer.ContextMenu>

            <Grid>

                <!-- Заглушка для пустого состояния -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,40"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BtV}}">
                    <TextBlock Text="📭"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="#FF333333"/>
                    <TextBlock Text="{x:Static res:Strings.Explorer_EmptyTitle}"
                               FontSize="14"
                               Foreground="#FF555555"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,4"/>
                    <TextBlock Text="{x:Static res:Strings.Explorer_EmptyHint}"
                               FontSize="11"
                               Foreground="#FF444444"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Сетка значков -->
                <ItemsControl x:Name="IconGrid"
                              ItemsSource="{Binding Items}"
                              Margin="8,8,8,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ExplorerItem}">
                            <Border x:Name="Bd"
                                    Width="92" Height="92"
                                    Margin="4"
                                    CornerRadius="6"
                                    Cursor="Hand"
                                    SnapsToDevicePixels="True"
                                    Tag="{Binding DataContext,
                                          RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BgBrush" Color="#00000000"/>
                                </Border.Background>

                                <!-- Двойной клик: зайти внутрь (папка) или открыть (макрос) -->
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.NavigateIntoCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <!-- Контекстное меню -->
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <!-- Переименовать -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_Rename}"
                                                  Command="{Binding PlacementTarget.Tag.RenameItemCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                        <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>

                                        <!-- Отключить макрос (Kind==Macro && IsEnabled==True) -->
                                        <MenuItem Header="{x:Static res:Strings.Macro_Disable}"
                                                  Command="{Binding PlacementTarget.Tag.ToggleMacroEnabledCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="{x:Static vm:ExplorerItemKind.Macro}"/>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.IsEnabled,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <!-- Включить макрос (Kind==Macro && IsEnabled==False) -->
                                        <MenuItem Header="{x:Static res:Strings.Macro_Enable}"
                                                  Command="{Binding PlacementTarget.Tag.ToggleMacroEnabledCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="{x:Static vm:ExplorerItemKind.Macro}"/>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.IsEnabled,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>

                                        <!-- Копировать макрос -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_Copy}"
                                                  Command="{Binding PlacementTarget.Tag.CopyMacroCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Macro}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <!-- Задать приоритет в очереди... -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_SetPriority}"
                                                  Command="{Binding PlacementTarget.Tag.SetMacroPriorityCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.CanSetPriority,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>
                                        <!-- Удалить -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_Delete}"
                                                  Command="{Binding PlacementTarget.Tag.DeleteItemCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <!-- Иконка + название -->
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="4">

                                    <!-- Контейнер иконки -->
                                    <Grid Width="44" Height="44" HorizontalAlignment="Center">
                                        <TextBlock x:Name="IconText"
                                                   Text="📁"
                                                   FontSize="34"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource GoldBrush}"/>

                                        <!-- Рубиновый бейдж Q — только для региона-очереди -->
                                        <Border x:Name="RegionBadge"
                                                Background="{StaticResource RubyBrush}"
                                                Width="17" Height="17"
                                                CornerRadius="4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,-3,-3"
                                                Visibility="Collapsed">
                                            <TextBlock Text="Q"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Золотой бейдж P{N} — приоритет очереди -->
                                        <Border x:Name="PriorityBadge"
                                                Background="#FFCCAA44"
                                                CornerRadius="4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="-3,-3,0,0"
                                                Padding="3,1"
                                                Visibility="Collapsed">
                                            <TextBlock Text="{Binding PriorityBadge}"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="#FF1A1000"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Название элемента -->
                                    <TextBlock x:Name="NameText"
                                               Text="{Binding Name}"
                                               FontSize="11"
                                               Foreground="#FFCCAA44"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxWidth="84"
                                               Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>

                            <!-- DataTemplate.Triggers: дифференциация по виду элемента -->
                            <DataTemplate.Triggers>

                                <!-- Регион: показываем рубиновый бейдж "Q" -->
                                <DataTrigger Binding="{Binding Kind}"
                                             Value="{x:Static vm:ExplorerItemKind.Region}">
                                    <Setter TargetName="RegionBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>

                                <!-- Макрос: меняем иконку на шестерёнку -->
                                <DataTrigger Binding="{Binding Kind}"
                                             Value="{x:Static vm:ExplorerItemKind.Macro}">
                                    <Setter TargetName="IconText" Property="Text"     Value="⚙"/>
                                    <Setter TargetName="IconText" Property="FontSize" Value="30"/>
                                </DataTrigger>

                                <!-- Макрос с приоритетом: золотой бейдж P{N} -->
                                <DataTrigger Binding="{Binding HasPriority}" Value="True">
                                    <Setter TargetName="PriorityBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>

                                <!-- Отключённый макрос: приглушённый Obsidian Dust стиль -->
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Bd"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.45"
                                                                 Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Bd"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                    <Setter TargetName="IconText"  Property="Foreground" Value="#FF888888"/>
                                    <Setter TargetName="NameText"  Property="Foreground" Value="#FF888888"/>
                                </DataTrigger>

                                <!-- Hover: плавная подсветка фона -->
                                <EventTrigger RoutedEvent="Border.MouseEnter" SourceName="Bd">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="BgBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FF1A1000"
                                                            Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave" SourceName="Bd">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="BgBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#00000000"
                                                            Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
