<UserControl x:Class="ARK.UI.Views.MacroExplorerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ARK.UI.ViewModels"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BtV"/>

        <!--
            BreadcrumbButtonStyle: OverridesDefaultStyle=True гарантирует, что кнопки хлебных крошек
            НЕ наследуют глобальный Button-стиль из Buttons.xaml.
        -->
        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="Padding"               Value="3,1"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Компактная кнопка для действий в панели контекстной привязки -->
        <Style x:Key="ProfileActionButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="#FF252525"/>
            <Setter Property="Foreground"            Value="#FFCCAA44"/>
            <Setter Property="BorderBrush"           Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="7,3"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FontSize"              Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E2500"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFCCAA44"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1A1800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileCheckBoxStyle" TargetType="CheckBox"
               BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="#FFCCAA44"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ProfileTextBoxStyle" TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background"     Value="#FF1A1A1A"/>
            <Setter Property="Foreground"     Value="#FFCCAA44"/>
            <Setter Property="Padding"        Value="5,3"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="CaretBrush"     Value="#FFCCAA44"/>
            <Setter Property="SelectionBrush" Value="#66CCAA44"/>
        </Style>

        <Style x:Key="ProfileComboBoxStyle" TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="#FF1A1A1A"/>
            <Setter Property="Foreground" Value="#FFCCAA44"/>
            <Setter Property="Padding"    Value="5,3"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Навигация / хлебные крошки -->
            <RowDefinition Height="Auto"/>  <!-- 1: Тулбар -->
            <RowDefinition Height="Auto"/>  <!-- 2: Панель контекстной привязки (AppFolder) -->
            <RowDefinition Height="*"/>     <!-- 3: Контент -->
        </Grid.RowDefinitions>

        <!-- ══ Строка навигации ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Command="{Binding NavigateBackCommand}"
                        Padding="8,4"
                        Margin="0,0,10,0">
                    <TextBlock Text="{x:Static res:Strings.Explorer_Back}" FontSize="12"/>
                </Button>

                <ItemsControl DockPanel.Dock="Left"
                              ItemsSource="{Binding Breadcrumbs}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:BreadcrumbItem}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource BreadcrumbButtonStyle}"
                                        Command="{Binding NavigateToCmd}">
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontSize="12"/>
                                </Button>
                                <TextBlock Text=" ›"
                                           Foreground="#FF555555"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ══ Панель инструментов ═══════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Orientation="Horizontal">

                <!-- Создать AppFolder (программу) -->
                <Button Command="{Binding CreateAppFolderCommand}"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖥" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Explorer_CreateProfile}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Создать обычную папку -->
                <Button Command="{Binding CreateFolderCommand}"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Explorer_CreateFolder}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Создать макрос -->
                <Button Command="{Binding CreateMacroCommand}"
                        Padding="9,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Explorer_CreateMacro}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Height="16"
                           Background="#FF3A3A3A"
                           VerticalAlignment="Center"
                           Margin="3,0,9,0"/>

                <!-- Импорт .arkmacro -->
                <Button Command="{Binding ImportMacroCommand}"
                        ToolTip="Импортировать макрос из файла .arkmacro"
                        Padding="9,4">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12"
                              Stretch="Uniform"
                              Data="M6,2 L6,10 M3,7 L6,10 9,7 M1,1 L11,1"
                              Stroke="{StaticResource GoldBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Margin="0,0,5,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Strings.Profile_Import}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══ Панель контекстной привязки (Row 2, видна только для AppFolder) ═ -->
        <Border Grid.Row="2"
                Visibility="{Binding IsContextBindingVisible, Converter={StaticResource BtV}}"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Background="#FF111111"
                Padding="12,10,12,12">
            <StackPanel>

                <TextBlock Text="{x:Static res:Strings.Profile_SectionTitle}"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="#FF666666"
                           Margin="0,0,0,9"/>

                <CheckBox Style="{StaticResource ProfileCheckBoxStyle}"
                          Content="{x:Static res:Strings.Profile_IsGlobal}"
                          IsChecked="{Binding CbIsGlobal}"/>

                <!-- Секция привязки к процессу — скрывается при CbIsGlobal=True -->
                <StackPanel Margin="0,4,0,0"
                            Visibility="{Binding CbIsProcessVisible, Converter={StaticResource BtV}}">

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Strings.Profile_TargetProcess}"
                                   Foreground="#FF888888"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource ProfileComboBoxStyle}"
                                  IsEditable="True"
                                  ItemsSource="{Binding ProcessSuggestions}"
                                  Text="{Binding CbTargetProcess, UpdateSourceTrigger=PropertyChanged}"
                                  TextSearch.TextPath="ProcessName"
                                  Margin="0,0,5,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ProcessInfo}">
                                    <StackPanel Orientation="Horizontal" Height="20">
                                        <Image Source="{Binding Icon}"
                                               Width="16" Height="16"
                                               Margin="0,0,5,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Text="{Binding ProcessName}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="#FFCCAA44"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="2"
                                Style="{StaticResource ProfileActionButtonStyle}"
                                Command="{Binding LoadProcessesCommand}"
                                Content="{x:Static res:Strings.Profile_RefreshProcesses}"
                                ToolTip="Обновить список запущенных процессов"/>
                    </Grid>

                    <CheckBox Style="{StaticResource ProfileCheckBoxStyle}"
                              Content="{x:Static res:Strings.Profile_FocusRequired}"
                              IsChecked="{Binding CbFocusRequired}"/>

                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Strings.Profile_WindowTitleFilter}"
                                   Foreground="#FF888888"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ProfileTextBoxStyle}"
                                 Text="{Binding CbTitleFilter, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Фильтр по части заголовка окна"/>
                    </Grid>

                </StackPanel>

                <Button Style="{StaticResource ProfileActionButtonStyle}"
                        Command="{Binding SaveContextBindingCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0"
                        Padding="12,5"
                        FontSize="11"
                        Content="{x:Static res:Strings.Profile_SaveChanges}"/>

            </StackPanel>
        </Border>

        <!-- ══ Контентная область ════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="3"
                      Background="Transparent"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- Контекстное меню пустого пространства (фильтрация Root / Inside) -->
            <ScrollViewer.ContextMenu>
                <ContextMenu>

                    <!-- ROOT ONLY: Создать программу -->
                    <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateProfile}"
                              Command="{Binding PlacementTarget.DataContext.CreateAppFolderCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsAtRoot,
                                                 RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>

                    <!-- INSIDE ONLY: Создать папку -->
                    <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateFolder}"
                              Command="{Binding PlacementTarget.DataContext.CreateFolderCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsInsideFolder,
                                                 RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>

                    <!-- INSIDE ONLY: Создать макрос -->
                    <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateMacro}"
                              Command="{Binding PlacementTarget.DataContext.CreateMacroCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsInsideFolder,
                                                 RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>

                    <!-- INSIDE ONLY: separator + Импорт -->
                    <Separator>
                        <Separator.Style>
                            <Style TargetType="Separator" BasedOn="{StaticResource ObsidianSeparatorStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsInsideFolder,
                                                 RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Separator.Style>
                    </Separator>

                    <MenuItem Header="{x:Static res:Strings.Profile_Import}"
                              Command="{Binding PlacementTarget.DataContext.ImportMacroCommand,
                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsInsideFolder,
                                                 RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>

                </ContextMenu>
            </ScrollViewer.ContextMenu>

            <Grid>

                <!-- Заглушка пустого состояния -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,40"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BtV}}">
                    <TextBlock Text="📭"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="#FF333333"/>
                    <TextBlock Text="{x:Static res:Strings.Explorer_EmptyTitle}"
                               FontSize="14"
                               Foreground="#FF555555"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,4"/>
                    <TextBlock Text="{x:Static res:Strings.Explorer_EmptyHint}"
                               FontSize="11"
                               Foreground="#FF444444"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Сетка значков -->
                <ItemsControl x:Name="IconGrid"
                              ItemsSource="{Binding Items}"
                              Margin="8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ExplorerItem}">
                            <Border x:Name="Bd"
                                    Width="92" Height="92"
                                    Margin="4"
                                    CornerRadius="6"
                                    Cursor="Hand"
                                    SnapsToDevicePixels="True"
                                    Tag="{Binding DataContext,
                                          RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BgBrush" Color="#00000000"/>
                                </Border.Background>

                                <!-- Одиночный клик — выбор (для панели привязки AppFolder) -->
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectItemCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                  CommandParameter="{Binding}"/>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.NavigateIntoCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <!-- ── Единое контекстное меню (секции управляются Visibility) ── -->
                                <Border.ContextMenu>
                                    <ContextMenu>

                                        <!-- ── СЕКЦИЯ: Папки (AppFolder / Folder) ────────────── -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateSubFolder}"
                                                  Command="{Binding PlacementTarget.Tag.CreateSubFolderCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.AppFolder}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Folder}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <MenuItem Header="{x:Static res:Strings.Explorer_CtxCreateMacroHere}"
                                                  Command="{Binding PlacementTarget.Tag.CreateMacroHereCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.AppFolder}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Folder}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <Separator>
                                            <Separator.Style>
                                                <Style TargetType="Separator" BasedOn="{StaticResource ObsidianSeparatorStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.AppFolder}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Folder}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Separator.Style>
                                        </Separator>

                                        <!-- ── СЕКЦИЯ: Только макросы ────────────────────────── -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_CtxEdit}"
                                                  Command="{Binding PlacementTarget.Tag.EditMacroCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Macro}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <!-- Отправить в Release (только Beta-макросы) -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_CtxSendToRelease}"
                                                  Command="{Binding PlacementTarget.Tag.PromoteCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="{x:Static vm:ExplorerItemKind.Macro}"/>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.IsRelease,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <!-- Вернуть в Beta (только Release-макросы) -->
                                        <MenuItem Header="{x:Static res:Strings.Explorer_CtxReturnToBeta}"
                                                  Command="{Binding PlacementTarget.Tag.DemoteCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="{x:Static vm:ExplorerItemKind.Macro}"/>
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.IsRelease,
                                                                           RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                           Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <Separator>
                                            <Separator.Style>
                                                <Style TargetType="Separator" BasedOn="{StaticResource ObsidianSeparatorStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Macro}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Separator.Style>
                                        </Separator>

                                        <MenuItem Header="{x:Static res:Strings.Explorer_CtxDuplicate}"
                                                  Command="{Binding PlacementTarget.Tag.DuplicateMacroCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Macro}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <!-- Экспорт (.arkmacro) — только Macro -->
                                        <MenuItem Header="{x:Static res:Strings.Profile_Export}"
                                                  Command="{Binding PlacementTarget.Tag.ExportMacroCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                     Value="{x:Static vm:ExplorerItemKind.Macro}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                        <!-- ── ОБЩАЯ СЕКЦИЯ: Переименовать / Удалить ───────────── -->
                                        <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>

                                        <MenuItem Header="{x:Static res:Strings.Explorer_Rename}"
                                                  Command="{Binding PlacementTarget.Tag.RenameItemCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>

                                        <Separator Style="{StaticResource ObsidianSeparatorStyle}"/>

                                        <MenuItem Header="{x:Static res:Strings.Explorer_Delete}"
                                                  Command="{Binding PlacementTarget.Tag.DeleteItemCommand,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>

                                    </ContextMenu>
                                </Border.ContextMenu>

                                <!-- ── Иконка + название ──────────────────────────────────── -->
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="4">

                                    <Grid Width="44" Height="44" HorizontalAlignment="Center">

                                        <!-- Основная иконка (emoji) -->
                                        <TextBlock x:Name="IconText"
                                                   Text="📁"
                                                   FontSize="34"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource GoldBrush}"/>

                                        <!-- Зелёный бейдж ✔ для Release-макросов -->
                                        <Border x:Name="ReleaseBadge"
                                                Background="#FF1A5C1A"
                                                Width="17" Height="17"
                                                CornerRadius="4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,-3,-3"
                                                Visibility="Collapsed">
                                            <TextBlock Text="✔"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       Foreground="#FF44FF44"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Оранжевый бейдж β — Beta-макросы -->
                                        <Border x:Name="BetaBadge"
                                                Background="#FFCC7700"
                                                Width="17" Height="17"
                                                CornerRadius="4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,-3,-3,0"
                                                Visibility="Collapsed">
                                            <TextBlock Text="β"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Золотой бейдж P{N} — приоритет очереди -->
                                        <Border x:Name="PriorityBadge"
                                                Background="#FFCCAA44"
                                                CornerRadius="4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="-3,-3,0,0"
                                                Padding="3,1"
                                                Visibility="Collapsed">
                                            <TextBlock Text="{Binding PriorityBadge}"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="#FF1A1000"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock x:Name="NameText"
                                               Text="{Binding Name}"
                                               FontSize="11"
                                               Foreground="#FFCCAA44"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxWidth="84"
                                               Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>

                            <!-- DataTemplate.Triggers: дифференциация вида -->
                            <DataTemplate.Triggers>

                                <!-- AppFolder: иконка 🖥 -->
                                <DataTrigger Binding="{Binding Kind}"
                                             Value="{x:Static vm:ExplorerItemKind.AppFolder}">
                                    <Setter TargetName="IconText" Property="Text"     Value="🖥"/>
                                    <Setter TargetName="IconText" Property="FontSize" Value="30"/>
                                </DataTrigger>

                                <!-- Макрос: иконка шестерёнки -->
                                <DataTrigger Binding="{Binding Kind}"
                                             Value="{x:Static vm:ExplorerItemKind.Macro}">
                                    <Setter TargetName="IconText" Property="Text"     Value="⚙"/>
                                    <Setter TargetName="IconText" Property="FontSize" Value="30"/>
                                </DataTrigger>

                                <!-- Release-макрос: зелёный бейдж ✔ -->
                                <DataTrigger Binding="{Binding IsRelease}" Value="True">
                                    <Setter TargetName="ReleaseBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>

                                <!-- Beta-макрос: оранжевый бейдж β -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Kind}"      Value="{x:Static vm:ExplorerItemKind.Macro}"/>
                                        <Condition Binding="{Binding IsRelease}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="BetaBadge" Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>

                                <!-- Макрос с приоритетом: золотой бейдж P{N} -->
                                <DataTrigger Binding="{Binding HasPriority}" Value="True">
                                    <Setter TargetName="PriorityBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>

                                <!-- Отключённый макрос: приглушённость -->
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Bd"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.45"
                                                                 Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Bd"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                    <Setter TargetName="IconText" Property="Foreground" Value="#FF888888"/>
                                    <Setter TargetName="NameText" Property="Foreground" Value="#FF888888"/>
                                </DataTrigger>

                                <!-- Hover: плавная подсветка фона -->
                                <EventTrigger RoutedEvent="Border.MouseEnter" SourceName="Bd">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="BgBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FF1A1000"
                                                            Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave" SourceName="Bd">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="BgBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#00000000"
                                                            Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
