<Window x:Class="ARK.UI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARK Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid>
        <!-- Золотая рамка подсветки найденного шаблона Vision Module -->
        <Rectangle x:Name="HighlightRect"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Fill="Transparent"
                   Stroke="{StaticResource GoldBrush}"
                   StrokeThickness="2"
                   Effect="{StaticResource GoldGlowEffect}"
                   Opacity="0"/>
        <Border x:Name="OverlayBorder"
                Background="#C0101010"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="15,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0"
                Effect="{StaticResource GoldGlowEffect}">
            <TextBlock x:Name="OverlayTextBlock"
                       FontSize="28"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource GoldBrush}"/>
        </Border>
        <!-- ИИ-ответ: потоковый HUD внизу экрана -->
        <Border x:Name="AiResponseBorder"
                Background="#D0101010"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="20,14"
                Margin="80,0,80,40"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                MaxHeight="220"
                Opacity="0"
                Effect="{StaticResource GoldGlowEffect}">
            <TextBlock x:Name="AiResponseTextBlock"
                       FontSize="18"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource GoldBrush}"/>
        </Border>
    </Grid>
</Window>
