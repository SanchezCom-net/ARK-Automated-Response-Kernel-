<Window x:Class="ARK.UI.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Переименовать"
        Width="340"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Inputs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Внешний отступ даёт место для GoldGlowEffect (иначе тень обрезается) -->
    <Border Margin="10">
        <Border Background="{StaticResource ObsidianBackgroundBrush}"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Effect="{StaticResource GoldGlowEffect}">

            <StackPanel Margin="16,12,16,16">

                <!-- ── Заголовок + кнопка закрыть ── -->
                <Grid Margin="0,0,0,14"
                      MouseLeftButtonDown="OnTitleBarDrag"
                      Cursor="SizeAll">
                    <TextBlock Text="Переименовать"
                               Foreground="{StaticResource GoldBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="24" Height="24"
                            Padding="4"
                            FontSize="12"
                            Content="✕"
                            Click="OnCloseClick"/>
                </Grid>

                <!-- ── Поле ввода (стиль из Inputs.xaml — золотое свечение при фокусе) ── -->
                <TextBox x:Name="NameBox"
                         Foreground="#FFF5D77F"
                         Margin="0,0,0,14"
                         KeyDown="OnKeyDown"/>

                <!-- ── Кнопка OK (стиль из Buttons.xaml) ── -->
                <Button Content="OK"
                        Width="90"
                        HorizontalAlignment="Right"
                        Click="OnOkClick"/>

            </StackPanel>
        </Border>
    </Border>
</Window>
