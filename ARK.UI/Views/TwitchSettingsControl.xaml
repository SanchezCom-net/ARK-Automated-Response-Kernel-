<UserControl x:Class="ARK.UI.Views.TwitchSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             xmlns:svc="clr-namespace:ARK.UI.Core.Services"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <svc:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <svc:PasswordEyeIconConverter         x:Key="PasswordEyeIcon"/>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#FF888888"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontFamily"  Value="Consolas"/>
                <Setter Property="Margin"      Value="0,0,0,4"/>
            </Style>

            <!-- Кнопка Obsidian Gold (малая) — дублируется локально, чтобы контрол был самодостаточным -->
            <Style x:Key="TwitchActionButton" TargetType="Button">
                <Setter Property="Background"      Value="#FF1A1A1A"/>
                <Setter Property="Foreground"      Value="{StaticResource GoldBrush}"/>
                <Setter Property="BorderBrush"     Value="#FF3A3A3A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14,7"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                    <Setter TargetName="Bd" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF2A1800"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- PasswordBox в стиле Obsidian Gold для OAuth токена -->
            <Style x:Key="TwitchPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
                <Setter Property="Background"               Value="#FF121212"/>
                <Setter Property="Foreground"               Value="#FFF5D77F"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Padding"                  Value="6,4,30,4"/>
                <Setter Property="CaretBrush"               Value="{StaticResource GoldBrush}"/>
                <Setter Property="SelectionBrush"           Value="{StaticResource GoldBrush}"/>
                <Setter Property="SelectionOpacity"         Value="0.3"/>
                <Setter Property="FontSize"                 Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="PasswordChar"             Value="●"/>
                <Setter Property="SnapsToDevicePixels"      Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type PasswordBox}">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FF2A2A2A"/>
                                </Border.BorderBrush>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              OverridesDefaultStyle="True"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Focus Safety: статические триггеры без Storyboard.TargetName — безопасны при удалении элемента -->
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="MainBorder" Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Кнопка-иконка (глазик токена) -->
            <Style x:Key="TwitchIconButtonStyle" TargetType="Button">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#22D4AF37"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#44D4AF37"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  FocusVisualStyle="{x:Null}">
        <StackPanel Margin="24,20,24,20">

            <!-- ══ Заголовок ══════════════════════════════════════════════════ -->
            <TextBlock Text="{x:Static res:Strings.Twitch_Title}"
                       Foreground="{StaticResource GoldBrush}"
                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <Rectangle Height="1" Fill="{StaticResource GoldBrush}" Opacity="0.3"
                       Margin="0,0,0,16"/>

            <!-- ══ Индикатор статуса ══════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF6B2222"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#FF9146FF"/>
                                    <Setter Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding TwitchStatusText}"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF6B2222"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Foreground" Value="#FF9146FF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- ══ Имя канала ════════════════════════════════════════════════ -->
            <TextBlock Text="{x:Static res:Strings.Twitch_ChannelLabel}"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding TwitchChannel, UpdateSourceTrigger=PropertyChanged}"
                     Foreground="#FFF5D77F"
                     Tag="channelname"
                     Margin="0,0,0,12"/>

            <!-- ══ Имя бота/аккаунта ════════════════════════════════════════ -->
            <TextBlock Text="{x:Static res:Strings.Twitch_UsernameLabel}"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding TwitchUsername, UpdateSourceTrigger=PropertyChanged}"
                     Foreground="#FFF5D77F"
                     Tag="botname"
                     Margin="0,0,0,12"/>

            <!-- ══ OAuth токен (с маскированием) ════════════════════════════ -->
            <TextBlock Text="{x:Static res:Strings.Twitch_OAuthLabel}"
                       Style="{StaticResource FieldLabel}"/>
            <!-- Reveal-поле: PasswordBox (маска) и TextBox (открытый) в Grid -->
            <Grid Margin="0,0,0,6">
                <!-- Слой 1: маскированный ввод -->
                <PasswordBox svc:PasswordBehavior.BoundPassword="{Binding OAuthToken, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TwitchPasswordBoxStyle}"
                             Visibility="{Binding IsTokenVisible, Converter={StaticResource InverseBoolToVis}}"
                             MaxLength="128"/>

                <!-- Слой 2: открытый TextBox -->
                <TextBox Text="{Binding OAuthToken, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#FFF5D77F"
                         Padding="6,4,30,4"
                         Tag="oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
                         Visibility="{Binding IsTokenVisible, Converter={StaticResource BoolToVis}}"
                         MaxLength="128"/>

                <!-- Кнопка-глазик -->
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="24" Height="24"
                        Margin="0,0,4,0"
                        Command="{Binding ToggleTokenVisibilityCommand}"
                        Style="{StaticResource TwitchIconButtonStyle}"
                        Focusable="False">
                    <Path Data="{Binding IsTokenVisible, Converter={StaticResource PasswordEyeIcon}}"
                          Fill="#FFD4AF37"
                          Stretch="Uniform"
                          Width="14" Height="14"/>
                </Button>
            </Grid>

            <!-- Подсказка получения токена -->
            <TextBlock Text="{x:Static res:Strings.Twitch_OAuthHint}"
                       Foreground="#FF555555"
                       FontSize="10" FontFamily="Consolas"
                       Margin="0,0,0,16"/>

            <!-- ══ Кнопки подключения ════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="{x:Static res:Strings.Twitch_ConnectBtn}"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource TwitchActionButton}"/>
                <Button Content="{x:Static res:Strings.Twitch_DisconnectBtn}"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource TwitchActionButton}"
                        Margin="8,0,0,0"/>
            </StackPanel>

            <!-- ══ Кнопка сохранения ════════════════════════════════════════ -->
            <Button Content="{x:Static res:Strings.Twitch_SaveBtn}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource TwitchActionButton}"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"/>

            <!-- ══ Справка !tts ═══════════════════════════════════════════════ -->
            <Rectangle Height="1" Fill="#FF2A2A2A" Margin="0,20,0,12"/>
            <TextBlock Text="{x:Static res:Strings.Twitch_TtsPermissionHint}"
                       Foreground="#FF555555"
                       FontSize="10" FontFamily="Consolas"
                       TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
