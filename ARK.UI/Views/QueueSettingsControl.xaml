<UserControl x:Class="ARK.UI.Views.QueueSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ARK.UI.ViewModels"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BtV"/>

        <!-- ── Кнопка панели инструментов ── -->
        <Style x:Key="QueueToolbarButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="#FF252525"/>
            <Setter Property="Foreground"            Value="#FFCCAA44"/>
            <Setter Property="BorderBrush"           Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="10,4"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FontSize"              Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E2500"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFCCAA44"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A2A00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Базовый стиль узла дерева ── -->
        <Style x:Key="QueueTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background"                   Value="Transparent"/>
            <Setter Property="Foreground"                   Value="#FFB0A070"/>
            <Setter Property="HorizontalContentAlignment"   Value="Stretch"/>
            <Setter Property="Padding"                      Value="2,4"/>
            <Setter Property="IsExpanded"                   Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Width="16" Background="Transparent" BorderThickness="0"
                                                  Focusable="False">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock x:Name="Arrow" Text="▶"
                                                                       FontSize="8" Foreground="#FF666666"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="18,0,0,0"
                                            Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1A1200"/>
                                <Setter Property="Foreground" Value="#FFD4AF37"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF141000"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ══ -->
        <Border Grid.Row="0" Padding="16,14,16,10"
                BorderBrush="#FF2A2A2A" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Nav_Queue}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFD4AF37"/>
                <TextBlock Text="Управление очередями выполнения макросов"
                           FontSize="10" Foreground="#FF666666" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══ Панель инструментов ══ -->
        <Border Grid.Row="1" Padding="10,7"
                BorderBrush="#FF2A2A2A" BorderThickness="0,0,0,1"
                Background="#FF0E0E0E">
            <WrapPanel Orientation="Horizontal">
                <Button Content="＋ Регион"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding AddRegionCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="＋ Папку"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding AddFolderCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="＋ Макрос"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding AddMacroCommand}"
                        Margin="0,0,5,0"/>
                <Separator Width="1" Background="#FF3A3A3A" Margin="4,2"/>
                <Button Content="✎ Переименовать"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding RenameItemCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="✖ Убрать макрос"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding RemoveMacroCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="★ Приоритет"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding SetPriorityCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="🗑 Удалить"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding DeleteItemCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="💾 Сохранить"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding SaveCommand}"/>
            </WrapPanel>
        </Border>

        <!-- ══ Дерево регионов ══ -->
        <Grid Grid.Row="2">
            <!-- Пустое состояние -->
            <TextBlock Text="Нет регионов. Нажмите «＋ Регион» для создания."
                       Foreground="#FF555555" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" Margin="20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RegionNodes.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TreeView Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding RegionNodes}"
                      ItemContainerStyle="{StaticResource QueueTreeItemStyle}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <TreeView.Resources>
                    <!-- Обработчик выбора узла -->
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource QueueTreeItemStyle}">
                        <EventSetter Event="Selected" Handler="OnTreeItemSelected"/>
                    </Style>

                    <!-- ── Шаблон региона ── -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:QueueRegionNodeVm}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <TextBlock Text="📋" FontSize="12"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- ── Шаблон папки ── -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:QueueFolderNodeVm}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <TextBlock Text="📁" FontSize="11"
                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- ── Шаблон макроса (листовой узел) ── -->
                    <DataTemplate DataType="{x:Type vm:QueueMacroRefNodeVm}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <StackPanel.ContextMenu>
                                <ContextMenu Tag="{Binding}">
                                    <MenuItem Header="★ Задать приоритет..."
                                              Click="OnSetPriorityMenuClick"/>
                                    <Separator/>
                                    <MenuItem Header="✖ Убрать из очереди"
                                              Click="OnRemoveMacroMenuClick"/>
                                </ContextMenu>
                            </StackPanel.ContextMenu>

                            <TextBlock Text="⚡" FontSize="10"
                                       Margin="0,0,5,0" VerticalAlignment="Center"
                                       Foreground="#FF888855"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="#FFD4AF37"/>
                            <!-- Бейдж приоритета: скрыт, если QueuePriority == 0 -->
                            <TextBlock Text="{Binding PriorityBadge}"
                                       FontSize="9" VerticalAlignment="Center"
                                       Foreground="#FFCCAA44" Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QueuePriority}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>

                </TreeView.Resources>
            </TreeView>
        </Grid>

        <!-- ══ Панель свойств выбранного региона ══ -->
        <Border Grid.Row="3"
                Padding="14,10"
                BorderBrush="#FF2A2A2A" BorderThickness="0,1,0,0"
                Background="#FF0C0C0C"
                Visibility="{Binding IsRegionSelected, Converter={StaticResource BtV}}">
            <StackPanel>
                <TextBlock Text="РЕЖИМ ВЫПОЛНЕНИЯ"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="#FF666666" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RadioStrict"
                                 Content="Очередь (StrictQueue)"
                                 GroupName="ExecMode"
                                 FontSize="11" Foreground="#FFB0A070"
                                 Margin="0,0,16,0"
                                 Checked="OnStrictQueueChecked"/>
                    <RadioButton x:Name="RadioConcurrent"
                                 Content="Параллельно (Concurrent)"
                                 GroupName="ExecMode"
                                 FontSize="11" Foreground="#FFB0A070"
                                 Checked="OnConcurrentChecked"/>
                </StackPanel>
                <TextBlock FontSize="9" Foreground="#FF555555" Margin="0,6,0,0" TextWrapping="Wrap">
                    <Run Text="StrictQueue"/>
                    <Run Text=" — макросы выполняются строго по одному в порядке приоритета.  "/>
                    <Run Text="Concurrent"/>
                    <Run Text=" — все поступившие макросы запускаются одновременно."/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
