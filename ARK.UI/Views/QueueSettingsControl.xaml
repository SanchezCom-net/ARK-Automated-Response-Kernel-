<UserControl x:Class="ARK.UI.Views.QueueSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ARK.UI.ViewModels"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BtV"/>

        <!-- ── Кнопка панели инструментов ── -->
        <Style x:Key="QueueToolbarButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="#FF252525"/>
            <Setter Property="Foreground"            Value="#FFCCAA44"/>
            <Setter Property="BorderBrush"           Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="10,4"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FontSize"              Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E2500"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFCCAA44"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A2A00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Заголовок -->
            <RowDefinition Height="Auto"/>  <!-- Тулбар -->
            <RowDefinition Height="Auto"/>  <!-- Хлебные крошки -->
            <RowDefinition Height="*"/>     <!-- Список -->
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ══ -->
        <Border Grid.Row="0" Padding="16,14,16,10"
                BorderBrush="#FF2A2A2A" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Nav_Queue}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFD4AF37"/>
                <TextBlock Text="Управление очередями выполнения макросов"
                           FontSize="10" Foreground="#FF666666" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══ Панель инструментов (кнопки авто-блокируются через CanExecute) ══ -->
        <Border Grid.Row="1" Padding="10,7"
                BorderBrush="#FF2A2A2A" BorderThickness="0,0,0,1"
                Background="#FF0E0E0E">
            <WrapPanel Orientation="Horizontal">
                <!-- Корневой уровень -->
                <Button Content="＋ Регион"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding AddRegionCommand}"
                        Margin="0,0,5,0"/>
                <!-- Внутри региона -->
                <Button Content="＋ Макрос"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding AddMacroCommand}"
                        Margin="0,0,5,0"/>
                <Separator Width="1" Background="#FF3A3A3A" Margin="4,2"/>
                <!-- Для выбранного региона (корень) -->
                <Button Content="✎ Переименовать"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding RenameRegionCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="🗑 Удалить регион"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding DeleteRegionCommand}"
                        Margin="0,0,5,0"/>
                <Separator Width="1" Background="#FF3A3A3A" Margin="4,2"/>
                <!-- Внутри региона -->
                <Button Content="⊘ Очистить"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding ClearRegionCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="★ Приоритет"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding SetPriorityCommand}"
                        Margin="0,0,5,0"/>
                <Button Content="✖ Убрать макрос"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding RemoveMacroCommand}"
                        Margin="0,0,5,0"/>
                <Separator Width="1" Background="#FF3A3A3A" Margin="4,2"/>
                <Button Content="⟳ Обновить"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
            </WrapPanel>
        </Border>

        <!-- ══ Хлебные крошки — навигация назад (видны только внутри региона) ══ -->
        <Border Grid.Row="2" Padding="10,6"
                BorderBrush="#FF2A2A2A" BorderThickness="0,0,0,1"
                Background="#FF0A0A0A"
                Visibility="{Binding IsInsideRegion, Converter={StaticResource BtV}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="← Назад"
                        Style="{StaticResource QueueToolbarButtonStyle}"
                        Command="{Binding NavigateBackCommand}"
                        Padding="8,3" Margin="0,0,12,0"/>
                <TextBlock Text="Очереди"
                           FontSize="11" Foreground="#FF555555"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  ›  "
                           FontSize="11" Foreground="#FF444444"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding BreadcrumbText}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#FFD4AF37"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ══ Основной список (RegionListItemVm / MacroQueueItemVm) ══ -->
        <Grid Grid.Row="3">
            <!-- Пустое состояние -->
            <TextBlock Text="{Binding EmptyStateText}"
                       Foreground="#FF555555" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" Margin="20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DisplayItems.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ListBox Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding DisplayItems}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     MouseDoubleClick="OnListMouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">

                <!-- ПКМ на пустом фоне: корень = Создать Регион, внутри региона = Добавить макрос -->
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="＋ Создать Регион" Click="OnCreateRegionMenuClick">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding PlacementTarget.DataContext.IsAtRoot,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem Header="＋ Добавить макрос" Click="OnAddMacroContextMenuClick">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding PlacementTarget.DataContext.IsInsideRegion,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                    </ContextMenu>
                </ListBox.ContextMenu>

                <!-- Стиль строки с подсветкой выделения -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="#FF1E1E1E"
                                            BorderThickness="0,0,0,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF1E1500"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3A2500"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF111000"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.Resources>

                    <!-- ── Шаблон региона ── -->
                    <DataTemplate DataType="{x:Type vm:RegionListItemVm}">
                        <Grid Margin="12,9">
                            <!-- ПКМ на регионе -->
                            <Grid.ContextMenu>
                                <ContextMenu Tag="{Binding}">
                                    <MenuItem Header="→ Открыть регион"    Click="OnDrillIntoMenuClick"/>
                                    <Separator/>
                                    <MenuItem Header="✎ Переименовать"     Click="OnRenameRegionMenuClick"/>
                                    <Separator/>
                                    <MenuItem Header="✖ Удалить регион"     Click="OnDeleteRegionMenuClick"/>
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📋" FontSize="18"
                                       Margin="0,0,12,0" VerticalAlignment="Center"
                                       Foreground="#FFD4AF37"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="#FFD4AF37"/>
                                <TextBlock Text="{Binding MacroCountLabel}"
                                           FontSize="10" Foreground="#FF666666"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="›" FontSize="18"
                                       Foreground="#FF444444" VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>

                    <!-- ── Шаблон макроса с полным путём и бейджами ── -->
                    <DataTemplate DataType="{x:Type vm:MacroQueueItemVm}">
                        <Grid Margin="12,8">
                            <!-- ПКМ на макросе -->
                            <Grid.ContextMenu>
                                <ContextMenu Tag="{Binding}">
                                    <MenuItem Header="★ Задать приоритет..."  Click="OnSetPriorityMenuClick"/>
                                    <Separator/>
                                    <MenuItem Header="✖ Удалить из региона"   Click="OnRemoveMacroMenuClick"/>
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Иконка ⚡ -->
                            <TextBlock Grid.Column="0" Text="⚡" FontSize="13"
                                       Margin="0,0,10,0" VerticalAlignment="Center"
                                       Foreground="#FF888855"/>

                            <!-- Имя + путь -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="#FFD4AF37"/>
                                <TextBlock Text="{Binding LocationPath}"
                                           FontSize="10" Foreground="#FF666666"
                                           Margin="0,2,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLocationPath}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- Правая колонка: бейдж приоритета + бейдж статуса -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0,0,0">

                                <!-- Жёлтый P: N -->
                                <Border CornerRadius="3" Background="#FFCCAA44"
                                        Padding="5,1" Margin="0,0,4,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPriority}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding PriorityBadge}"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#FF1A1200"/>
                                </Border>

                                <!-- Зелёный ✔ Release -->
                                <Border Background="#FF1A5C1A"
                                        Width="16" Height="16"
                                        CornerRadius="3" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRelease}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="✔" FontSize="8" FontWeight="Bold"
                                               Foreground="#FF44FF44"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Оранжевый β Beta -->
                                <Border Background="#FFCC7700"
                                        Width="16" Height="16"
                                        CornerRadius="3" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRelease}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="β" FontSize="9" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>

                </ListBox.Resources>
            </ListBox>
        </Grid>

    </Grid>
</UserControl>
