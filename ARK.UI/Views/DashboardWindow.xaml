<Window x:Class="ARK.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ARK.UI.Core.Models"
        xmlns:views="clr-namespace:ARK.UI.Views"
        xmlns:res="clr-namespace:ARK.UI.Resources"
        xmlns:svc="clr-namespace:ARK.UI.Core.Services"
        Title="ARK — Dashboard"
        Width="904" Height="604"
        MinWidth="704" MinHeight="454"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <svc:InverseBoolToVisibilityConverter x:Key="InverseBtV"/>

            <!-- Конвертер NodeState → цвет -->
            <Style x:Key="NodeStateTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF888888"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:NodeState.Executing}">
                        <Setter Property="Foreground" Value="#FFD4AF37"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:NodeState.Success}">
                        <Setter Property="Foreground" Value="#FF7FBB4A"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:NodeState.Failed}">
                        <Setter Property="Foreground" Value="#FFD32F2F"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль строк ListView нод -->
            <Style x:Key="NodeListItemStyle" TargetType="ListViewItem">
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="Foreground"   Value="{StaticResource GoldBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush"  Value="#FF1E1E1E"/>
                <Setter Property="Padding"      Value="8,6"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF1A1000"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF2A1800"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FFD4AF37"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль кнопок навигации боковой панели -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="Foreground"       Value="#FF888888"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="Padding"          Value="16,10"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FontSize"         Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF1A1000"/>
                                    <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF2A1800"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TabControl без видимых заголовков -->
            <Style x:Key="HiddenTabControlStyle" TargetType="TabControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Основной контейнер с тенью и рамкой.
         Margin="2" даёт 2px прозрачного буфера вокруг — артефакты сглаживания
         CornerRadius уходят в прозрачность окна, а не в пиксели монитора. -->
    <Border Background="{StaticResource ObsidianBackgroundBrush}"
            BorderBrush="{StaticResource GoldBrush}"
            BorderThickness="1.5"
            CornerRadius="10"
            ClipToBounds="True"
            Margin="2"
            Effect="{StaticResource GoldGlowEffect}"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════
                 Боковая панель (Sidebar)
                 ══════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="#FF0C0C0C"
                    CornerRadius="8.5,0,0,8.5">
                <DockPanel LastChildFill="False">

                    <!-- Логотип / область перетаскивания -->
                    <Border DockPanel.Dock="Top"
                            x:Name="DragHandle"
                            Padding="16,20,16,16"
                            Cursor="SizeAll"
                            MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                        <StackPanel>
                            <TextBlock Text="ARK"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}"
                                       Effect="{StaticResource GoldGlowEffect}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Automated Response Kernel"
                                       FontSize="9"
                                       Foreground="#FF555555"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                            <Rectangle Height="1" Margin="0,12,0,0"
                                       Fill="#FF2A2A2A"/>
                        </StackPanel>
                    </Border>

                    <!-- Навигационные кнопки -->
                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowExplorerCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗂" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_Macros}"/>
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowAutomationCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬡" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_Blueprint}"/>
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowQueueCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📑" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_Queue}"/>
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowAiSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤖" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_AiAndNetwork}"/>
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowLogsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_Logs}"/>
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowObsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎥" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_Obs}"/>
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowTwitchCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static res:Strings.Nav_Twitch}"/>
                        </StackPanel>
                    </Button>

                    <!-- Кнопка закрытия внизу: рубиновое свечение при наведении -->
                    <Button DockPanel.Dock="Bottom"
                            Margin="12,12"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click">
                        <TextBlock Text="{x:Static res:Strings.Dashboard_Close}"/>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Вертикальный разделитель -->
            <Rectangle Grid.Column="0"
                       Width="1"
                       HorizontalAlignment="Right"
                       Fill="#FF2A2A2A"/>

            <!-- ══════════════════════════════
                 Контентная область (Tabs)
                 ══════════════════════════════ -->
            <TabControl Grid.Column="1"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Style="{StaticResource HiddenTabControlStyle}"
                        Background="Transparent">

                <!-- ──── Tab 0: Проводник макросов ──── -->
                <TabItem>
                    <views:MacroExplorerControl DataContext="{Binding MacroExplorer}"/>
                </TabItem>

                <!-- ──── Tab 1: Blueprint-редактор нод ──── -->
                <TabItem>
                    <views:BlueprintEditorControl DataContext="{Binding BlueprintEditor}"/>
                </TabItem>

                <!-- ──── Tab 2: Очередь ──── -->
                <TabItem>
                    <views:QueueSettingsControl DataContext="{Binding QueueSettings}"/>
                </TabItem>

                <!-- ──── Tab 3: ИИ и Сеть ──── -->
                <TabItem>
                    <views:AiSettingsControl DataContext="{Binding Settings}"/>
                </TabItem>

                <!-- ──── Tab 4: Логи ──── -->
                <TabItem>
                    <views:LogsTerminalControl/>
                </TabItem>

                <!-- ──── Tab 5: Стриминг и OBS ──── -->
                <TabItem>
                    <views:ObsSettingsControl DataContext="{Binding ObsSettings}"/>
                </TabItem>

                <!-- ──── Tab 6: Twitch Chat ──── -->
                <TabItem>
                    <views:TwitchSettingsControl DataContext="{Binding TwitchSettings}"/>
                </TabItem>
            </TabControl>

            <!-- Кастомный Win32-ResizeGrip: нативное перетаскивание нижнего правого угла -->
            <Button x:Name="ResizeButton"
                    Grid.Column="1"
                    Style="{StaticResource RubyResizeGripStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="24" Height="24"
                    Cursor="SizeNWSE"
                    Panel.ZIndex="10"/>

            <!-- ══════════════════════════════════════════════════════════
                 Оверлей инициализации: виден пока IsReady == false.
                 Блокирует UI, показывает прогресс warm-up последовательности.
                 ══════════════════════════════════════════════════════════ -->
            <Grid Grid.ColumnSpan="2"
                  Panel.ZIndex="100"
                  Visibility="{Binding IsReady, Converter={StaticResource InverseBtV}}">
                <Grid.Background>
                    <SolidColorBrush Color="#E0121212"/>
                </Grid.Background>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="260">

                    <!-- Логотип ARK -->
                    <TextBlock Text="ARK"
                               FontSize="36"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource GoldBrush}"
                               Effect="{StaticResource GoldGlowEffect}"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Automated Response Kernel"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               Foreground="#FF555555"
                               Margin="0,0,0,28"/>

                    <!-- Индикатор прогресса (Gold / indeterminate) -->
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Background="#FF1E1E1E"
                                 Foreground="{StaticResource GoldBrush}"
                                 BorderThickness="0"
                                 Margin="0,0,0,14"/>

                    <TextBlock Text="Инициализация системы..."
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Foreground="#FF888888"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
