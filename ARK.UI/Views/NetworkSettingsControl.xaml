<UserControl x:Class="ARK.UI.Views.NetworkSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:ARK.UI.Resources"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Static res:Strings.Net_Header}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource GoldBrush}"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1"
                   Text="{x:Static res:Strings.Net_ServerUrl}"
                   Foreground="#FF888888"
                   FontSize="11"
                   Margin="0,0,0,4"/>

        <TextBox Grid.Row="2"
                 Text="{Binding WebSocketUrl, UpdateSourceTrigger=PropertyChanged}"
                 Background="#FF181818"
                 Foreground="{StaticResource GoldBrush}"
                 BorderBrush="#FF2A2A2A"
                 BorderThickness="1"
                 Padding="8,6"
                 FontFamily="Consolas"
                 CaretBrush="{StaticResource GoldBrush}"
                 Margin="0,0,0,16"/>

        <!-- Статус подключения: цветная точка + текст.
             DataTrigger привязан к IsNetworkConnected (bool), а не к строке —
             это locale-независимо и не ломается при смене языка. -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Ellipse Width="10" Height="10"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#FFD32F2F"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNetworkConnected}" Value="True">
                                <Setter Property="Fill" Value="#FF7FBB4A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FFD32F2F"/>
                        <Setter Property="Text"       Value="{Binding NetworkStatusText}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNetworkConnected}" Value="True">
                                <Setter Property="Foreground" Value="#FF7FBB4A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <Button Grid.Row="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Command="{Binding ReconnectNetworkCommand}">
            <TextBlock Text="{x:Static res:Strings.Net_Reconnect}"/>
        </Button>
    </Grid>

</UserControl>
