<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ARK.UI.Core.Services">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ══════════════════════════════════════════════════════════════════════
         TextBox — Obsidian Gold, анимированная рамка, placeholder
    ══════════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background"               Value="#FF121212"/>
        <Setter Property="Foreground"               Value="#FFE0E0E0"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="6,4"/>
        <Setter Property="CaretBrush"               Value="{StaticResource GoldBrush}"/>
        <Setter Property="SelectionBrush"           Value="{StaticResource GoldBrush}"/>
        <Setter Property="SelectionOpacity"         Value="0.3"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels"      Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FF2A2A2A"/>
                        </Border.BorderBrush>
                        <Grid>
                            <!-- Текст подсказки переопределяется через Tag элемента;
                                 без Tag действует прежний дефолт "Введите текст..." -->
                            <TextBlock x:Name="PlaceholderText"
                                       Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, TargetNullValue='Введите текст...'}"
                                       Foreground="#FF606060"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          OverridesDefaultStyle="True"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text"              Value=""/>
                                <Condition Property="IsKeyboardFocused" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="MainBorder" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CheckBox — Obsidian Gold: тёмный бокс с Path-галочкой
    ══════════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground"           Value="#FFE0E0E0"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="VerticalAlignment"    Value="Center"/>
        <Setter Property="SnapsToDevicePixels"  Value="True"/>
        <Setter Property="Cursor"               Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <Border x:Name="CheckBorder"
                                Width="16" Height="16"
                                CornerRadius="3"
                                Background="#FF0D0D0D"
                                BorderBrush="#FF3A3A3A"
                                BorderThickness="1.5"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Checkmark"
                                  Data="M3,8 L6,11 L13,4"
                                  Stroke="{StaticResource GoldBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Margin="2"
                                  Visibility="Collapsed"/>
                        </Border>

                        <ContentPresenter Margin="7,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Checkmark"    Property="Visibility"   Value="Visible"/>
                            <Setter TargetName="CheckBorder"  Property="BorderBrush"  Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="CheckBorder"  Property="Background"   Value="#FF100D00"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="CheckBorder" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                        </Trigger>
                        <!-- Промежуточное состояние (null) -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Checkmark"   Property="Visibility"  Value="Visible"/>
                            <Setter TargetName="Checkmark"   Property="Opacity"     Value="0.5"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#FF666666"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         ComboBoxItem — тёмный фон, золотой hover-градиент
    ══════════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="Foreground"            Value="#FFE0E0E0"/>
        <Setter Property="Padding"               Value="8,5"/>
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="ItemBd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF1A1000" Offset="0"/>
                                        <GradientStop Color="#FF261A00" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#FFD4AF37"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="#FF1E1500"/>
                            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         ComboBox — Obsidian Gold: тёмный Popup, шеврон, анимация рамки.
         BackgroundBorder = постоянный тёмный фон (#FF121212, hardcoded).
         MainBorder       = только анимируемая рамка (Background=Transparent).
         OverridesDefaultStyle=True вытесняет системный белый фон Windows.
    ══════════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="OverridesDefaultStyle"    Value="True"/>
        <Setter Property="Background"               Value="#FF121212"/>
        <Setter Property="Foreground"               Value="#FFE0E0E0"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="6,4"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels"      Value="True"/>
        <Setter Property="MaxDropDownHeight"        Value="280"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                        </Grid.ColumnDefinitions>

                        <!-- Z=0  Постоянный тёмный фон — hardcoded, не зависит от темы -->
                        <Border x:Name="BackgroundBorder"
                                Grid.ColumnSpan="2"
                                Background="#FF121212"
                                CornerRadius="4"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="True"/>

                        <!-- Z=1  Выбранный элемент (не редактируемый режим) -->
                        <Grid Grid.Column="0" ClipToBounds="True" IsHitTestVisible="False">
                            <ContentPresenter x:Name="PART_ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="#FFF5D77F"
                                              TextElement.FontFamily="Consolas"
                                              TextElement.FontSize="12"
                                              TextElement.FontWeight="SemiBold"
                                              svc:MarqueeBehavior.IsEnabled="True"/>
                        </Grid>

                        <!-- Z=2  Редактируемый TextBox (IsEditable=True) -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Grid.Column="0"
                                 Foreground="#FFF5D77F"
                                 Background="Transparent"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                                 Margin="{TemplateBinding Padding}"
                                 Visibility="Hidden"
                                 CaretBrush="{StaticResource GoldBrush}"
                                 SelectionBrush="{StaticResource GoldBrush}"
                                 SelectionOpacity="0.3"
                                 VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                 OverridesDefaultStyle="True">
                            <TextBox.Template>
                                <ControlTemplate TargetType="{x:Type TextBox}">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Background="Transparent"
                                                  OverridesDefaultStyle="True"
                                                  Focusable="False"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden"/>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>

                        <!-- Z=3  Шеврон (декоративный, без hit-test) -->
                        <Path x:Name="ChevronArrow"
                              Grid.Column="1"
                              Data="M4,6 L8,10 L12,6"
                              Stroke="#FF888888"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"/>

                        <!-- Z=4  Прозрачная кнопка-переключатель: вся ширина (не-редактируемый режим) -->
                        <ToggleButton x:Name="FullToggle"
                                      Grid.ColumnSpan="2"
                                      IsChecked="{Binding IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                      Focusable="False"
                                      OverridesDefaultStyle="True"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Z=5  Прозрачная кнопка только над шевроном (редактируемый режим) -->
                        <ToggleButton x:Name="ChevronToggle"
                                      Grid.Column="1"
                                      IsChecked="{Binding IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                      Focusable="False"
                                      Visibility="Collapsed"
                                      OverridesDefaultStyle="True"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Z=6  Анимируемая рамка (фон прозрачный — сквозь неё виден BackgroundBorder) -->
                        <Border x:Name="MainBorder"
                                Grid.ColumnSpan="2"
                                Background="Transparent"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF2A2A2A"/>
                            </Border.BorderBrush>
                        </Border>

                        <!-- Z=7  Выпадающий список -->
                        <Popup x:Name="PART_Popup"
                               Grid.ColumnSpan="2"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PopupAnimation="Fade"
                               VerticalOffset="2">
                            <Border Background="#FF0D0D0D"
                                    BorderBrush="#FFD4AF37"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{Binding MaxDropDownHeight, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer OverridesDefaultStyle="True"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- Редактируемый режим: TextBox видим, ContentPresenter скрыт -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="PART_ContentSite"     Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="FullToggle"           Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="ChevronToggle"        Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <!-- Dropdown открыт: золотой шеврон + золотая рамка + свечение -->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="ChevronArrow" Property="Stroke"       Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="MainBorder"   Property="BorderBrush"  Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="MainBorder"   Property="Effect"       Value="{StaticResource GoldGlowEffect}"/>
                        </Trigger>

                        <!-- Hover: золотое свечение + шеврон подсвечивается -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder"   Property="Effect" Value="{StaticResource GoldGlowEffect}"/>
                            <Setter TargetName="ChevronArrow" Property="Stroke" Value="#FFCCAA44"/>
                        </Trigger>

                        <!-- Фокус клавиатуры: золотая рамка + свечение -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="MainBorder" Property="Effect"      Value="{StaticResource GoldGlowEffect}"/>
                        </Trigger>

                        <!-- Недоступен: полупрозрачность -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Именованный алиас — для явного применения в DataTemplate-ах через Style="{StaticResource ObsidianComboBoxStyle}" -->
    <Style x:Key="ObsidianComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}"/>

    <!-- Именованный алиас для CheckBox — для явного применения через Style="{StaticResource ObsidianCheckBoxStyle}" -->
    <Style x:Key="ObsidianCheckBoxStyle" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}"/>


    <!-- ══════════════════════════════════════════════════════════════════════
         MarqueeTextBlockStyle — бегущая строка при наведении.
         Требует Grid ClipToBounds="True" как родительский контейнер.
         Анимация запускается только если текст не умещается (overflow > 0).
    ══════════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="MarqueeTextBlockStyle" TargetType="TextBlock">
        <Setter Property="TextWrapping"      Value="NoWrap"/>
        <Setter Property="TextTrimming"      Value="None"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="svc:MarqueeBehavior.IsEnabled" Value="True"/>
    </Style>

</ResourceDictionary>
