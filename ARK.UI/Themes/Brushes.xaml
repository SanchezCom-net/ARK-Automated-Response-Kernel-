<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Фон: глубокий угольно-чёрный → благородный графитовый (45°) -->
    <LinearGradientBrush x:Key="ObsidianBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF121212" Offset="0"/>
        <GradientStop Color="#FF1A1A1A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Золото: глубокая латунь → классическое золото → сияющее золото (90°) -->
    <LinearGradientBrush x:Key="GoldBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFAA7C11" Offset="0"/>
        <GradientStop Color="#FFD4AF37" Offset="0.5"/>
        <GradientStop Color="#FFF5D77F" Offset="1"/>
    </LinearGradientBrush>

    <!-- Золотое свечение (x:Shared=False — каждый элемент получает свой экземпляр) -->
    <DropShadowEffect x:Key="GoldGlowEffect" x:Shared="False"
                      Color="#FFD4AF37"
                      BlurRadius="15"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.6"/>

    <!-- Тонкие тёмные рамки -->
    <SolidColorBrush x:Key="DarkBorderBrush" Color="#FF2A2A2A"/>

    <!-- Рубин: глубокий благородный багровый → яркий неоновый красный (90° вертикаль) -->
    <LinearGradientBrush x:Key="RubyBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF800000" Offset="0"/>
        <GradientStop Color="#FFFF3B30" Offset="1"/>
    </LinearGradientBrush>

    <!-- Красное неоновое свечение (рубин, x:Shared=False — свой экземпляр на каждый элемент) -->
    <DropShadowEffect x:Key="RubyGlowEffect" x:Shared="False"
                      Color="#FFFF3B30"
                      BlurRadius="12"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.85"/>

    <!-- Серебро: нейтральный платиново-серебряный металлик -->
    <SolidColorBrush x:Key="SilverDataPortBrush" Color="#FFD3D3D3"/>

    <!-- Серебряное неоновое свечение (x:Shared=False — свой экземпляр на каждый элемент) -->
    <DropShadowEffect x:Key="SilverGlowEffect" x:Shared="False"
                      Color="#FFD3D3D3"
                      BlurRadius="12"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.8"/>

    <!-- Сочный зелёный: провод от TriggerRootNode (точка входа) -->
    <SolidColorBrush x:Key="TriggerWireBrush" Color="#FF22C55E"/>

    <!-- Свечение зелёного старт-провода (x:Shared=False — свой экземпляр на каждый элемент) -->
    <DropShadowEffect x:Key="TriggerWireGlowEffect" x:Shared="False"
                      Color="#FF22C55E"
                      BlurRadius="10"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.85"/>

    <!-- Мятно-бирюзовый: провода и порты блоков очереди (QueueBlock) -->
    <SolidColorBrush x:Key="QueueWireBrush" Color="#FF10B981"/>

    <!-- Свечение мятного провода QueueBlock (x:Shared=False) -->
    <DropShadowEffect x:Key="QueueWireGlowEffect" x:Shared="False"
                      Color="#FF10B981"
                      BlurRadius="10"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.85"/>

    <!-- Сиренево-синий: провод Custom Data Out (кастомные данные) -->
    <SolidColorBrush x:Key="CustomDataWireBrush" Color="#FF7F7FBF"/>

    <!-- Свечение сиренево-синего провода (x:Shared=False) -->
    <DropShadowEffect x:Key="CustomDataWireGlowEffect" x:Shared="False"
                      Color="#FF7F7FBF"
                      BlurRadius="10"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.8"/>

    <!-- Грифельно-синий: провод Black Box Log (диагностика) -->
    <SolidColorBrush x:Key="BlackBoxWireBrush" Color="#FF5B9BD5"/>

    <!-- Свечение грифельно-синего провода (x:Shared=False) -->
    <DropShadowEffect x:Key="BlackBoxWireGlowEffect" x:Shared="False"
                      Color="#FF5B9BD5"
                      BlurRadius="10"
                      ShadowDepth="0"
                      Direction="0"
                      Opacity="0.8"/>

    <!-- ══ Эффекты для проводов (всегда включены, мягкие) ══════════════════ -->
    <!-- Используются на самих линиях Безье через DataTrigger на Stroke.      -->
    <!-- BlurRadius=8, Opacity=0.5 — тонкое неоновое свечение в покое.        -->
    <DropShadowEffect x:Key="GoldWireEffect"       x:Shared="False" Color="#FFD4AF37" BlurRadius="8"  ShadowDepth="0" Opacity="0.50"/>
    <DropShadowEffect x:Key="RubyWireEffect"       x:Shared="False" Color="#FFFF3B30" BlurRadius="8"  ShadowDepth="0" Opacity="0.50"/>
    <DropShadowEffect x:Key="SilverWireEffect"     x:Shared="False" Color="#FFD3D3D3" BlurRadius="6"  ShadowDepth="0" Opacity="0.35"/>
    <DropShadowEffect x:Key="CustomDataWireEffect" x:Shared="False" Color="#FF7F7FBF" BlurRadius="8"  ShadowDepth="0" Opacity="0.50"/>
    <DropShadowEffect x:Key="BlackBoxWireEffect"   x:Shared="False" Color="#FF5B9BD5" BlurRadius="8"  ShadowDepth="0" Opacity="0.50"/>
    <DropShadowEffect x:Key="TriggerWireEffect"    x:Shared="False" Color="#FF22C55E" BlurRadius="8"  ShadowDepth="0" Opacity="0.55"/>
    <DropShadowEffect x:Key="QueueWireEffect"      x:Shared="False" Color="#FF10B981" BlurRadius="8"  ShadowDepth="0" Opacity="0.55"/>

    <!-- ══ Пульсирующие эффекты (активное исполнение макроса) ══════════════ -->
    <!-- Используются на PulsePath: белое ядро (Stroke=White) + цветной нимб. -->
    <!-- BlurRadius=18, Opacity=0.95 — яркий неоновый орб на тёмном фоне.     -->
    <DropShadowEffect x:Key="GoldPulseEffect"       x:Shared="False" Color="#FFD4AF37" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
    <DropShadowEffect x:Key="RubyPulseEffect"       x:Shared="False" Color="#FFFF3B30" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
    <DropShadowEffect x:Key="SilverPulseEffect"     x:Shared="False" Color="#FFD3D3D3" BlurRadius="16" ShadowDepth="0" Opacity="0.90"/>
    <DropShadowEffect x:Key="CustomDataPulseEffect" x:Shared="False" Color="#FFAAAAFF" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
    <DropShadowEffect x:Key="BlackBoxPulseEffect"   x:Shared="False" Color="#FF7BC4FF" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
    <DropShadowEffect x:Key="TriggerPulseEffect"    x:Shared="False" Color="#FF22C55E" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
    <DropShadowEffect x:Key="QueuePulseEffect"      x:Shared="False" Color="#FF10B981" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>

</ResourceDictionary>
