<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Themes/Brushes.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Глобальный стиль Button — применяется ко всем Button без x:Key -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background"      Value="#FF1E1E1E"/>
        <Setter Property="Foreground"      Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,6"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <!-- Изменяемый Brush для анимации цвета рамки -->
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FF2A2A2A"/>
                        </Border.BorderBrush>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Наведение: фон чуть светлее + золотое свечение -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#FF252525"/>
                            <Setter TargetName="MainBorder" Property="Effect"     Value="{StaticResource GoldGlowEffect}"/>
                        </Trigger>
                        <!-- Анимация: рамка золотеет при наведении (150 мс) -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetName="MainBorder"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FFD4AF37"
                                        Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Анимация: рамка темнеет при уходе мыши (150 мс) -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetName="MainBorder"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FF2A2A2A"
                                        Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Нажатие: фон проседает, свечение убирается -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#FF181818"/>
                            <Setter TargetName="MainBorder" Property="Effect"     Value="{x:Null}"/>
                        </Trigger>
                        <!-- Анимация: рамка меняется на глубокую латунь при нажатии (50 мс) -->
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetName="MainBorder"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FFAA7C11"
                                        Duration="0:0:0.05"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Анимация: рамка возвращается к золоту после отпускания (100 мс) -->
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetName="MainBorder"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FFD4AF37"
                                        Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Недоступен -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка "Закрыть": серая в норме; при наведении — золотой контур + рубиновый текст -->
    <Style x:Key="CloseButtonStyle" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="Foreground"            Value="#FF666666"/>
        <Setter Property="BorderThickness"       Value="1"/>
        <Setter Property="Padding"               Value="12,6"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FF2A2A2A"/>
                        </Border.BorderBrush>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Наведение: текст → рубин, контур → золото, свечение → рубин -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground"              Value="{StaticResource RubyBrush}"/>
                            <Setter TargetName="Bd" Property="Effect" Value="{StaticResource RubyGlowEffect}"/>
                        </Trigger>
                        <!-- Анимация рамки при наведении: серый → золото (150 мс) -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetName="Bd"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FFD4AF37"
                                        Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Анимация рамки при уходе мыши: золото → серый (150 мс) -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetName="Bd"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FF2A2A2A"
                                        Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FF1A0000"/>
                            <Setter TargetName="Bd" Property="Effect"     Value="{x:Null}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════
         ContextMenu системного трея — стиль "Obsidian Gold"
         ══════════════════════════════════════════════════════════════ -->

    <Style x:Key="ObsidianContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <Setter Property="MinWidth"              Value="190"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="#E6101010"
                            BorderBrush="{StaticResource GoldBrush}"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Padding="0,4"
                            Effect="{StaticResource GoldGlowEffect}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Обычный пункт меню: золото + плавная подсветка при наведении -->
    <Style x:Key="ObsidianMenuItemStyle" TargetType="MenuItem">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground"            Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontFamily"            Value="Segoe UI"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid Margin="4,1">
                        <!-- Слой подсветки: золотисто-угольный градиент (fade-in/out) -->
                        <Border x:Name="HoverBg" CornerRadius="4" Opacity="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF2A1800" Offset="0"/>
                                    <GradientStop Color="#FF1A1000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Контент: иконка галочки + заголовок -->
                        <Grid Margin="12,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CheckMark"
                                       Grid.Column="0"
                                       Text="✓" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource GoldBrush}"
                                       Visibility="Collapsed"/>
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#FFF5D77F"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"  Value="#FFFFC857"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                            <Setter Property="Cursor"      Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Пункт "Выход": багрово-угольный градиент + красная рамка при наведении -->
    <Style x:Key="ExitMenuItemStyle" TargetType="MenuItem">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground"            Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontFamily"            Value="Segoe UI"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid Margin="4,1">
                        <!-- Слой подсветки: багрово-угольный градиент + красная рамка -->
                        <Border x:Name="ExitHoverBg"
                                CornerRadius="4"
                                BorderThickness="1"
                                Opacity="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E63B0000" Offset="0"/>
                                    <GradientStop Color="#FF101010" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF8B0000"/>
                            </Border.BorderBrush>
                        </Border>
                        <!-- Контент -->
                        <ContentPresenter ContentSource="Header"
                                          Margin="28,6,12,6"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ExitHoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ExitHoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#FFFF6060"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль кнопки кастомного ResizeGrip: три рубиновых диагональных полосы -->
    <Style x:Key="RubyResizeGripStyle" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" SnapsToDevicePixels="True">
                        <Path x:Name="GripLines"
                              Data="M 16,20 L 20,16 M 11,20 L 20,11 M 6,20 L 20,6"
                              Stroke="{StaticResource RubyBrush}"
                              StrokeThickness="2.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Opacity="0.7"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GripLines" Property="Opacity" Value="1.0"/>
                            <Setter TargetName="GripLines" Property="Effect"
                                    Value="{StaticResource RubyGlowEffect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ResizeGrip в рубиново-красном градиенте с неоновым свечением при наведении -->
    <Style TargetType="{x:Type ResizeGrip}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ResizeGrip}">
                    <Border Background="Transparent" Width="16" Height="16" SnapsToDevicePixels="True">
                        <Path x:Name="GripDots"
                              Data="M 12,12 L 14,12 L 14,14 L 12,14 Z
                                    M 8,12 L 10,12 L 10,14 L 8,14 Z
                                    M 12,8 L 14,8 L 14,10 L 12,10 Z
                                    M 4,12 L 6,12 L 6,14 L 4,14 Z
                                    M 8,8 L 10,8 L 10,10 L 8,10 Z
                                    M 12,4 L 14,4 L 14,6 L 12,6 Z"
                              Fill="{StaticResource RubyBrush}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GripDots" Property="Effect"
                                    Value="{StaticResource RubyGlowEffect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Разделитель меню: тонкая тёмная линия с боковыми отступами (именованный — для трей-меню) -->
    <Style x:Key="ObsidianSeparatorStyle" TargetType="Separator">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Height"                Value="1"/>
        <Setter Property="Margin"                Value="5,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Height="1" Fill="#FF2A2A2A"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         ГЛОБАЛЬНЫЕ СТИЛИ (без x:Key) — применяются ко всем элементам,
         у которых нет явно заданного Style. Трей-меню использует именованные
         стили выше и не затрагивается.
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- ГЛОБАЛЬНЫЙ ContextMenu: полупрозрачный угольный фон + золотая рамка -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <Setter Property="MinWidth"              Value="160"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="#F9121212"
                            BorderBrush="{StaticResource GoldBrush}"
                            BorderThickness="1.2"
                            CornerRadius="6"
                            Padding="3,5,3,5"
                            Effect="{StaticResource GoldGlowEffect}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ГЛОБАЛЬНЫЙ MenuItem: золото + плавный hover; "Удалить" → рубиновый hover -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground"            Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontFamily"            Value="Segoe UI"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid Margin="4,1">
                        <!-- Слой 1: золотисто-угольная подсветка (все пункты, кроме "Удалить") -->
                        <Border x:Name="HoverBg" CornerRadius="4" Opacity="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF2A1800" Offset="0"/>
                                    <GradientStop Color="#FF1A1000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Слой 2: багрово-угольная подсветка (только Header="Удалить") -->
                        <Border x:Name="DeleteHoverBg" CornerRadius="4" Opacity="0" Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E63B0000" Offset="0"/>
                                    <GradientStop Color="#FF101010" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Контент: галочка IsCheckable + заголовок -->
                        <Grid Margin="12,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CheckMark"
                                       Grid.Column="0"
                                       Text="✓" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource GoldBrush}"
                                       Visibility="Collapsed"/>
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>

                        <!-- Header="Удалить": переключаем фон с gold на ruby -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Header}"
                                     Value="Удалить">
                            <Setter TargetName="HoverBg"       Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="DeleteHoverBg" Property="Visibility" Value="Visible"/>
                        </DataTrigger>

                        <!-- Плавный fade-in видимого слоя при наведении -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="DeleteHoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="DeleteHoverBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Обычный пункт: неоновое золото при наведении -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#FFF5D77F"/>
                        </Trigger>

                        <!-- "Удалить" при наведении: рубиновый текст + свечение
                             (MultiTrigger позже — выигрывает у простого IsMouseOver-Trigger) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Header"      Value="Удалить"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter Property="Foreground" Value="{StaticResource RubyBrush}"/>
                                <Setter Property="Effect"     Value="{StaticResource RubyGlowEffect}"/>
                            </MultiTrigger.Setters>
                        </MultiTrigger>

                        <!-- Отмечен (IsCheckable) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <!-- Недоступен: приглушённый текст, курсор не меняется на руку -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#FFFFC857"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Cursor"     Value="Arrow"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ГЛОБАЛЬНЫЙ Separator: тонкая тёмная линия — глобальный аналог ObsidianSeparatorStyle -->
    <Style TargetType="{x:Type Separator}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Height"                Value="1"/>
        <Setter Property="Margin"                Value="5,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Height="1" Fill="#FF2A2A2A"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ГЛОБАЛЬНЫЙ ToolTip: полупрозрачный угольный акрил + золотая рамка + мягкое свечение -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"            Value="#CC0A0A0A"/>
        <Setter Property="Foreground"            Value="#FFD4AF37"/>
        <Setter Property="FontSize"              Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource GoldBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4">
                        <Border.Effect>
                            <DropShadowEffect Color="#FFD4AF37"
                                              ShadowDepth="0"
                                              BlurRadius="8"
                                              Opacity="0.5"/>
                        </Border.Effect>
                        <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
